    <!-- ═══════════════════════════════════════════
         STYLES
         ═══════════════════════════════════════════ -->
    <style>
      html,
      body {
        width: 100%;
        max-width: 100vw;
        overflow-x: hidden !important;
      }

      /* ── CUSTOM CURSOR ── */
      .custom-cursor {
        position: fixed;
        pointer-events: none;
        z-index: var(--z-cursor);
        top: 0;
        left: 0;
        mix-blend-mode: multiply;
      }
      .cursor-dot {
        position: absolute;
        width: 8px;
        height: 8px;
        background: var(--color-sakura-500);
        border-radius: 50%;
        transform: translate(-50%, -50%);
        transition: transform 0.1s var(--ease-default);
      }
      .cursor-ring {
        position: absolute;
        width: 32px;
        height: 32px;
        border: 2px solid var(--color-sakura-400);
        border-radius: 50%;
        transform: translate(-50%, -50%);
        opacity: 0.6;
        transition:
          transform 0.15s var(--ease-out),
          width 0.2s,
          height 0.2s,
          opacity 0.2s;
      }
      .cursor-hover .cursor-ring {
        width: 50px;
        height: 50px;
        opacity: 0.4;
        border-color: var(--color-cobalt-400);
      }
      @media (pointer: coarse) {
        .custom-cursor {
          display: none;
        }
      }

      /* ── HERO ── */
      .hero-section {
        background: var(--gradient-hero);
      }
      .parallax-layer {
        position: absolute;
        inset: 0;
        pointer-events: none;
      }
      .hero-blob {
        position: absolute;
        border-radius: 50%;
        filter: blur(90px);
        pointer-events: none;
      }
      .hero-blob-1 {
        width: 500px;
        height: 500px;
        top: -15%;
        left: -10%;
        background: var(--color-sakura-200);
        opacity: 0.4;
      }
      .hero-blob-2 {
        width: 400px;
        height: 400px;
        bottom: -10%;
        right: -10%;
        background: var(--color-cobalt-200);
        opacity: 0.3;
      }
      .hero-blob-3 {
        width: 250px;
        height: 250px;
        top: 50%;
        left: 55%;
        background: var(--color-void-200);
        opacity: 0.25;
      }
      .hero-speed-lines {
        position: absolute;
        inset: 0;
        background-image: repeating-conic-gradient(
          from 0deg at 50% 50%,
          transparent 0deg,
          transparent 8.5deg,
          rgba(247, 37, 133, 0.03) 8.5deg,
          rgba(247, 37, 133, 0.03) 9deg
        );
        pointer-events: none;
        animation: rotateLines 60s linear infinite;
      }
      @keyframes rotateLines {
        from {
          transform: rotate(0deg);
        }
        to {
          transform: rotate(360deg);
        }
      }
      .hero-grid {
        position: absolute;
        inset: 0;
        background-image:
          linear-gradient(var(--color-border-soft) 1px, transparent 1px),
          linear-gradient(90deg, var(--color-border-soft) 1px, transparent 1px);
        background-size: 60px 60px;
        -webkit-mask-image: radial-gradient(
          ellipse at center,
          black 0%,
          transparent 70%
        );
        mask-image: radial-gradient(
          ellipse at center,
          black 0%,
          transparent 70%
        );
        pointer-events: none;
      }

      /* Floating manga panels */
      .manga-panel-float {
        position: absolute;
        background: var(--color-bg-card);
        border: 2px solid var(--color-text);
        border-radius: var(--radius-manga);
        padding: 0.5rem 1rem;
        box-shadow: 3px 3px 0px var(--color-text);
        pointer-events: none;
        animation: float 6s ease-in-out infinite;
        z-index: 2;
      }
      .manga-panel-1 {
        top: 22%;
        left: 5%;
        animation-delay: 0s;
      }
      .manga-panel-2 {
        top: 55%;
        right: 5%;
        animation-delay: 1.5s;
      }
      .manga-panel-3 {
        bottom: 25%;
        left: 8%;
        animation-delay: 3s;
      }
      @media (max-width: 1024px) {
        .manga-panel-float {
          display: none;
        }
      }

      /* Hero heading */
      .hero-heading {
        font-size: clamp(2.2rem, 6vw, 5.5rem);
        font-weight: 800;
        letter-spacing: -0.03em;
        line-height: 1.05;
      }
      .hero-italic {
        font-family: var(--font-serif);
        font-style: italic;
        color: var(--color-text-brand);
      }
      .hero-line {
        display: inline-block;
        overflow: hidden;
      }

      /* Hero stats */
      .hero-stats {
        display: inline-flex;
        align-items: center;
        gap: 2rem;
        margin-top: 3rem;
        padding: 1.25rem 2rem;
        background: var(--color-bg-card);
        border: 2px solid var(--color-text);
        border-radius: var(--radius-full);
        box-shadow: 4px 4px 0px var(--color-text);
      }
      @media (max-width: 640px) {
        .hero-stats {
          gap: 1rem;
          padding: 1rem 1.25rem;
          flex-wrap: wrap;
          border-radius: var(--radius-xl);
        }
      }
      .hero-stat-item {
        text-align: center;
      }
      .hero-stat-num {
        font-family: var(--font-display);
        font-size: clamp(1.5rem, 3vw, 2rem);
        font-weight: 900;
        background: var(--gradient-brand);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        line-height: 1;
      }
      .hero-stat-suffix {
        font-family: var(--font-mono);
        font-size: 0.7rem;
        color: var(--color-text-subtle);
        margin-left: 2px;
      }
      .hero-stat-label {
        display: block;
        font-family: var(--font-mono);
        font-size: 0.6rem;
        color: var(--color-text-subtle);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-top: 0.2rem;
      }
      .hero-stat-sep {
        width: 1px;
        height: 36px;
        background: var(--color-border-strong);
        flex-shrink: 0;
      }

      /* Scroll hint */
      .hero-scroll-hint {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
        margin-top: 4rem;
        font-family: var(--font-mono);
        font-size: 0.65rem;
        color: var(--color-text-subtle);
        letter-spacing: 0.2em;
        text-transform: uppercase;
      }
      .scroll-line {
        width: 1px;
        height: 48px;
        background: linear-gradient(
          to bottom,
          var(--color-sakura-400),
          transparent
        );
        animation: scrollLine 2s ease-in-out infinite;
      }
      @keyframes scrollLine {
        0% {
          transform: scaleY(0);
          transform-origin: top;
        }
        49% {
          transform: scaleY(1);
          transform-origin: top;
        }
        50% {
          transform: scaleY(1);
          transform-origin: bottom;
        }
        100% {
          transform: scaleY(0);
          transform-origin: bottom;
        }
      }

      /* Magnetic button */
      .magnetic-btn {
        position: relative;
        will-change: transform;
      }
      .btn-inner {
        display: block;
        pointer-events: none;
      }

      /* ── DATA-ANIM — initial hidden state ── */
      [data-anim] {
        opacity: 0;
        transform: translateY(28px);
        transition:
          opacity 0.7s var(--ease-spring),
          transform 0.7s var(--ease-spring);
      }
      [data-anim].anim-visible {
        opacity: 1;
        transform: none;
      }

      /* ── MARQUEE ── */
      .marquee-outer {
        overflow: hidden;
      }
      .marquee-inner {
        display: flex;
        align-items: center;
        width: max-content;
        animation: marquee 24s linear infinite;
        gap: 0;
      }
      .marquee-outer:hover .marquee-inner {
        animation-play-state: paused;
      }
      .client-logo {
        padding: 0 3rem;
        font-family: var(--font-serif);
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--color-text-subtle);
        white-space: nowrap;
        transition: color var(--duration-base);
      }
      .client-logo:hover {
        color: var(--color-text-brand);
      }
      @keyframes marquee {
        from {
          transform: translateX(0);
        }
        to {
          transform: translateX(-50%);
        }
      }

      /* ── ABOUT ── */
      .about-section {
        background: #f3eeea;
      }
      .about-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 5rem;
        align-items: center;
      }
      @media (max-width: 768px) {
        .about-grid {
          grid-template-columns: 1fr;
          gap: 2.5rem;
        }
      }
      .about-img-outer {
        position: relative;
      }
      .about-img-inner {
        position: relative;
        border-radius: var(--radius-xl);
        overflow: hidden;
        border: 2px solid var(--color-text);
        box-shadow: 6px 6px 0px var(--color-text);
        aspect-ratio: 4/5;
      }
      .about-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.6s var(--ease-default);
        will-change: transform;
      }
      .about-img-inner:hover .about-img {
        transform: scale(1.04);
      }
      .about-frame-deco {
        position: absolute;
        top: -12px;
        left: -12px;
        z-index: 2;
        width: 64px;
        height: 64px;
        border-top: 3px solid var(--color-sakura-400);
        border-left: 3px solid var(--color-sakura-400);
        border-radius: 4px 0 0 0;
        pointer-events: none;
      }
      .about-frame-deco-br {
        position: absolute;
        bottom: -12px;
        right: -12px;
        z-index: 2;
