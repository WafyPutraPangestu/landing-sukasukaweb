    <!-- ══════════════════════════════════════════════════════════
         THREE.JS — Semua 3D object di-generate procedurally
         Tidak perlu asset file .glb sama sekali!
         ══════════════════════════════════════════════════════════ -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script>
      (function () {
        "use strict";

        /* ══ HELPERS ══ */
        const INK = 0x0a0a0a;
        const PINK = 0xe6007e;
        const CYAN = 0x00aeef;
        const YELLW = 0xfff200;
        const PAPER = 0xf4f1ea;
        const WHITE = 0xfdfcf8;

        function mkRenderer(canvas, w, h, alpha) {
          const r = new THREE.WebGLRenderer({
            canvas,
            antialias: true,
            alpha: alpha !== false,
          });
          r.setPixelRatio(Math.min(window.devicePixelRatio, 2));
          r.setSize(w, h, false);
          r.setClearColor(0x000000, 0);
          return r;
        }

        function mkCamera(fov, near, far, pos) {
          const c = new THREE.PerspectiveCamera(fov, 1, near, far);
          c.position.set(...pos);
          c.lookAt(0, 0, 0);
          return c;
        }

        /* Cel-shaded / toon material */
        function toonMat(color, specular) {
          const m = new THREE.MeshToonMaterial({ color });
          return m;
        }

        /* Outline mesh for cartoon effect */
        function addOutline(geo, parent, scale = 1.06, color = INK) {
          const mat = new THREE.MeshBasicMaterial({
            color,
            side: THREE.BackSide,
          });
          const m = new THREE.Mesh(geo, mat);
          m.scale.setScalar(scale);
          parent.add(m);
        }

        /* ══════════════════════════════════════
         HERO 3D — Floating laptop/browser object
         ══════════════════════════════════════ */
        function initHero3D() {
          const canvas = document.getElementById("hero3dCanvas");
          if (!canvas || !window.THREE) return;

          const W = 520,
            H = 400;
          const renderer = mkRenderer(canvas, W, H);
          const scene = new THREE.Scene();
          const camera = mkCamera(40, 0.1, 100, [0, 1.5, 7]);

          // Lighting — flat toon lighting
          scene.add(new THREE.AmbientLight(0xffffff, 0.7));
          const dir = new THREE.DirectionalLight(0xffffff, 1.2);
          dir.position.set(3, 5, 4);
          scene.add(dir);
          const dir2 = new THREE.DirectionalLight(PINK, 0.4);
          dir2.position.set(-3, -1, 2);
          scene.add(dir2);

          // Root group — will float & rotate gently
          const root = new THREE.Group();
          scene.add(root);

          /* ── Laptop base ── */
          const baseGeo = new THREE.BoxGeometry(4, 0.2, 2.6);
          const baseMat = toonMat(PAPER);
          const base = new THREE.Mesh(baseGeo, baseMat);
          base.position.y = -1;
          root.add(base);
          addOutline(baseGeo, base, 1.05);

          /* Keyboard grid on base (decorative lines) */
          for (let r = 0; r < 3; r++) {
            for (let c = 0; c < 9; c++) {
              const keyGeo = new THREE.BoxGeometry(0.3, 0.04, 0.25);
              const keyMat = new THREE.MeshToonMaterial({ color: 0xddd8cc });
              const key = new THREE.Mesh(keyGeo, keyMat);
              key.position.set(-1.8 + c * 0.42, 0.12, -0.7 + r * 0.36);
              base.add(key);
            }
          }

          // Trackpad
          const tpGeo = new THREE.BoxGeometry(1.2, 0.04, 0.8);
          const tp = new THREE.Mesh(
            tpGeo,
            new THREE.MeshToonMaterial({ color: 0xccc8be }),
          );
          tp.position.set(0, 0.12, 0.75);
          base.add(tp);

          /* ── Screen panel ── */
          const screenHinge = new THREE.Group();
          screenHinge.position.y = -0.9;
          screenHinge.position.z = -1.3;
          root.add(screenHinge);

          // Screen frame (black bezel)
          const frameGeo = new THREE.BoxGeometry(4, 2.8, 0.12);
          const frame = new THREE.Mesh(frameGeo, toonMat(INK));
          frame.position.y = 1.3;
          screenHinge.add(frame);
          addOutline(frameGeo, frame, 1.03);

          // Screen surface (paper white)
          const screenGeo = new THREE.BoxGeometry(3.6, 2.4, 0.08);
          const screenMat = toonMat(WHITE);
          const screen = new THREE.Mesh(screenGeo, screenMat);
          screen.position.set(0, 1.3, 0.04);
          screenHinge.add(screen);

          // Code lines on screen (PINK / CYAN / INK)
          const codeColors = [PINK, CYAN, INK, PINK, CYAN, INK, PINK, CYAN];
          const codeWidths = [1.2, 2.0, 0.9, 1.6, 1.0, 1.8, 1.3, 0.7];
          codeColors.forEach((col, i) => {
            const geo = new THREE.BoxGeometry(codeWidths[i], 0.09, 0.02);
            const m = new THREE.Mesh(
              geo,
              new THREE.MeshToonMaterial({
                color: col,
                opacity: i % 3 === 2 ? 0.3 : 0.9,
                transparent: true,
              }),
            );
            m.position.set(-0.9 + (i % 2) * 0.15, 0.95 - i * 0.25, 0.12);
            screenHinge.add(m);
          });

          // Cursor blink (pink rect)
          const cursorGeo = new THREE.BoxGeometry(0.06, 0.14, 0.02);
          const cursor = new THREE.Mesh(
            cursorGeo,
            new THREE.MeshToonMaterial({ color: PINK }),
          );
          cursor.position.set(0.6, -0.05, 0.12);
          screenHinge.add(cursor);

          // Pink corner accent on screen
          const accentGeo = new THREE.BoxGeometry(0.4, 0.4, 0.02);
          const accentMat = new THREE.MeshToonMaterial({ color: PINK });
          const accent = new THREE.Mesh(accentGeo, accentMat);
          accent.position.set(1.65, 2.45, 0.08);
          screenHinge.add(accent);

          // Screen initial tilt
          screenHinge.rotation.x = -Math.PI * 0.18;

          /* ── Floating chips beside laptop ── */
          function floatingChip(color, w, h, ox, oy, oz) {
            const g = new THREE.Group();
            const boxGeo = new THREE.BoxGeometry(w, h, 0.08);
            const box = new THREE.Mesh(boxGeo, toonMat(color));
            g.add(box);
            addOutline(boxGeo, box, 1.06);
            const dotGeo = new THREE.SphereGeometry(0.08, 8, 8);
            const dot = new THREE.Mesh(dotGeo, toonMat(INK));
            dot.position.set(-w / 2 + 0.18, 0, 0.06);
            g.add(dot);
            g.position.set(ox, oy, oz);
            return g;
          }
          const chip1 = floatingChip(WHITE, 1.2, 0.35, 2.6, 0.8, 1);
          const chip2 = floatingChip(WHITE, 1.4, 0.35, -2.8, -0.2, 0.5);
          const chip3 = floatingChip(YELLW, 1.0, 0.35, 2.4, -1.0, 0.5);
          root.add(chip1, chip2, chip3);

          /* ── Halftone dot decoration ── */
          const dotGroup = new THREE.Group();
          for (let i = 0; i < 12; i++) {
            const dg = new THREE.SphereGeometry(0.06, 6, 6);
            const dm = new THREE.Mesh(
              dg,
              new THREE.MeshToonMaterial({
                color: PINK,
                opacity: 0.4,
                transparent: true,
              }),
            );
            dm.position.set(
              2.2 + (i % 4) * 0.22,
              -1.6 + Math.floor(i / 4) * 0.22,
              0,
            );
            dotGroup.add(dm);
          }
          root.add(dotGroup);

          /* Tilt whole laptop slightly */
          root.rotation.y = 0.2;
          root.rotation.x = 0.05;

          /* ── Animate ── */
          let t = 0;
          function animate() {
            requestAnimationFrame(animate);
            t += 0.012;
            root.position.y = Math.sin(t * 0.8) * 0.18;
            root.rotation.y = 0.2 + Math.sin(t * 0.4) * 0.06;
            chip1.position.y = 0.8 + Math.sin(t + 0.5) * 0.12;
            chip2.position.y = -0.2 + Math.sin(t + 1.2) * 0.14;
            chip3.position.y = -1.0 + Math.sin(t + 2.0) * 0.1;
            // Cursor blink
            cursor.visible = Math.sin(t * 4) > 0;
            renderer.render(scene, camera);
          }
          animate();

          // Mouse parallax
          canvas
            .closest(".hero-3d-stage")
            .addEventListener("mousemove", (e) => {
              const r = canvas.getBoundingClientRect();
              const mx = ((e.clientX - r.left) / r.width - 0.5) * 2;
              const my = ((e.clientY - r.top) / r.height - 0.5) * 2;
              root.rotation.y = 0.2 + mx * 0.15;
              root.rotation.x = 0.05 - my * 0.08;
            });
          canvas
            .closest(".hero-3d-stage")
            .addEventListener("mouseleave", () => {
              root.rotation.y = 0.2;
              root.rotation.x = 0.05;
            });
        }

        /* ══════════════════════════════════════
         PANEL 3D ICONS — mini kenapa kami icons
         ══════════════════════════════════════ */
        function initPanelIcons() {
          document.querySelectorAll(".panel-3d-canvas").forEach((canvas) => {
            const type = canvas.dataset.icon;
            const renderer = mkRenderer(canvas, 80, 80);
            const scene = new THREE.Scene();
