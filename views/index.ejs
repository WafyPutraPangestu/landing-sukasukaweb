    <%- include('partials/navbar') %>

    <main id="main-content">
      <!-- ══════════════════════════════════════════════════════════
           SECTION 1: HERO — Comic Cover Page Full Bleed
           ══════════════════════════════════════════════════════════ -->
      <section id="beranda" class="hero-comic" aria-labelledby="hero-heading">
        <!-- BG Layers -->
        <div class="hero-halftone-bg" aria-hidden="true"></div>
        <div class="hero-speedlines" aria-hidden="true"></div>
        <div class="hero-panel-border" aria-hidden="true"></div>

        <!-- Floating comic panel decorations -->
        <div
          class="hero-floater hero-floater-1 animate-float"
          aria-hidden="true"
