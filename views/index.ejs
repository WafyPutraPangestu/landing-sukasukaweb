            <div
              class="hero-heading-block"
              data-anim="fade-up"
              data-delay="160"
            >
              <h1 id="hero-heading" class="hero-h1">
                <span class="h1-line h1-outline">JASA</span>
                <span class="h1-line h1-filled">PEMBUATAN</span>
                <span class="h1-line h1-splash">WEBSITE</span>
              </h1>
              <div class="hero-annotation">
                <svg class="annot-arrow" viewBox="0 0 60 30" fill="none">
                  <path
                    d="M5 15 Q20 5 50 20"
                    stroke="var(--pink)"
                    stroke-width="2.5"
                    stroke-dasharray="4 2"
                    fill="none"
                  />
                  <polygon points="46,16 54,22 48,26" fill="var(--pink)" />
                </svg>
                <span class="font-hand text-sm" style="color: var(--pink)"
