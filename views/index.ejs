                  new THREE.MeshToonMaterial({ color: i % 2 ? CYAN : PINK }),
                );
                l.position.set(-0.1, 0.6 - i * 0.16, 0.1);
                l.rotation.x = -0.2;
                group.add(l);
              }
            } else if (type === "chat") {
              // Chat bubble icon
              const bg = new THREE.Mesh(
