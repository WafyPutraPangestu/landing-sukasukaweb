<!DOCTYPE html>
<html lang="id">
  <head>
    <%- include('partials/head') %>

    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "LocalBusiness",
            "@id": "https://sukasukaweb.com/#business",
            "name": "SukaSuka.web",
            "alternateName": "Suka-Suka Web",
            "description": "Software house Indonesia spesialis pembuatan web app, company profile, landing page, dan sistem kasir modern untuk UMKM dan perusahaan.",
            "url": "https://sukasukaweb.com",
            "telephone": "+6285706193924",
            "email": "halo@sukasukaweb.com",
            "foundingDate": "2022",
            "areaServed": {
              "@type": "Country",
              "name": "Indonesia"
            },
            "serviceType": [
              "Pembuatan Website",
              "Web App Development",
              "Landing Page",
              "Company Profile",
              "Sistem Kasir POS",
              "UI/UX Design",
              "Software House"
            ],
            "priceRange": "Rp 1.200.000 - Negosiasi",
            "currenciesAccepted": "IDR",
            "paymentAccepted": "Bank Transfer, QRIS",
            "sameAs": [
              "https://instagram.com/sukasukaweb",
              "https://linkedin.com/company/sukasukaweb",
              "https://github.com/sukasukaweb"
            ]
          },
          {
            "@type": "WebSite",
            "@id": "https://sukasukaweb.com/#website",
            "url": "https://sukasukaweb.com",
            "name": "SukaSuka.web",
            "description": "Jasa pembuatan website profesional Indonesia",
            "inLanguage": "id-ID",
            "publisher": {
              "@id": "https://sukasukaweb.com/#business"
            }
          },
          {
            "@type": "FAQPage",
            "mainEntity": [
              {
                "@type": "Question",
                "name": "Bagaimana sistem pembayaran pembuatan website di SukaSuka.web?",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "Sistem kami mewajibkan DP 50% di awal untuk mengikat komitmen serta modal pembelian domain dan hosting. Pelunasan 50% sisanya dilakukan setelah website selesai dan siap online."
                }
              },
              {
                "@type": "Question",
                "name": "Apakah ada biaya perpanjangan tahunan untuk website?",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "Ya, ada. Biaya yang Anda bayarkan di awal sudah termasuk gratis Domain dan Hosting untuk tahun pertama. Untuk tahun kedua dan seterusnya, akan ada biaya perpanjangan server dan domain."
                }
              },
              {
                "@type": "Question",
                "name": "Berapa lama waktu pengerjaan website?",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "Paket Landing Page memakan waktu 3-7 hari kerja. Paket Bisnis 1-2 minggu, dan Paket Kustom menyesuaikan tingkat kerumitan sistem."
                }
              },
              {
                "@type": "Question",
                "name": "Apakah SukaSuka.web memberikan proposal resmi?",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "Tentu. Setelah Anda menghubungi kami via WhatsApp, kami akan mengirimkan format penawaran (proposal) ringkas namun profesional yang mencakup keuntungan, detail paket, dan langkah kerja."
                }
              }
            ]
          }
        ]
      }
    </script>
  </head>

  <body class="flex flex-col min-h-screen overflow-x-hidden w-full">
    <%- include('partials/navbar') %>

    <main class="flex-grow" id="main-content">
      <!-- ═══════════════════════════════════════════
           HERO
           ═══════════════════════════════════════════ -->
      <section
        id="beranda"
        class="relative flex items-center min-h-screen pt-28 pb-20 overflow-hidden"
        aria-labelledby="hero-heading"
      >
        <div class="hero-blob hero-blob-1" aria-hidden="true"></div>
        <div class="hero-blob hero-blob-2" aria-hidden="true"></div>
        <div class="hero-blob hero-blob-3" aria-hidden="true"></div>
        <div class="hero-grid" aria-hidden="true"></div>

        <div class="container px-6 mx-auto relative z-10">
          <div class="max-w-4xl mx-auto text-center">
            <div
              class="inline-flex items-center gap-2 badge badge-brand animate-fade-up mb-8"
              aria-live="polite"
            >
              <span class="status-dot" aria-hidden="true"></span>
              Open for Project — Indonesia
            </div>

            <div class="flex justify-center mb-8 animate-fade-up delay-1">
              <div class="logo-img-wrap">
                <img
                  src="/images/logo-atas.png"
                  alt="Logo SukaSuka.web — Software House Indonesia"
                  class="h-16 w-auto mx-auto"
                  width="200"
                  height="64"
                />
              </div>
            </div>

            <h1
              id="hero-heading"
              class="animate-fade-up delay-1 mb-6 text-balance hero-heading"
            >
              Jasa Pembuatan Website<br />
              Profesional <em class="hero-italic">Modern</em> untuk<br />
              <span class="text-gradient">Bisnis Indonesia</span>
            </h1>

            <p
              class="text-lg md:text-xl text-[var(--color-text-muted)] animate-fade-up delay-2 mb-10 text-balance max-w-2xl mx-auto leading-relaxed"
            >
              Kami bantu
              <strong class="text-[var(--color-text)]"
                >UMKM dan Perusahaan</strong
              >
              membangun Web App, Company Profile, hingga Sistem Kasir (POS) yang
              cepat, modern, dan ramah mesin pencari (SEO-ready).
            </p>

            <div
              class="flex flex-col sm:flex-row gap-4 justify-center animate-fade-up delay-3"
            >
              <a
                href="https://wa.me/6285706193924?text=Halo%20SukaSuka.web,%20saya%20ingin%20konsultasi%20gratis%20pembuatan%20website."
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn-primary btn-lg"
                aria-label="Konsultasi gratis pembuatan website via WhatsApp"
              >
                💬 Konsultasi Gratis
              </a>
              <a
                href="#paket"
                class="btn btn-secondary btn-lg"
                aria-label="Lihat paket harga pembuatan website"
              >
                Lihat Paket Harga →
              </a>
            </div>

            <div
              class="hero-scroll-hint animate-fade-up delay-4"
              aria-hidden="true"
            >
              <div class="scroll-line"></div>
              <span>Scroll</span>
            </div>
          </div>
        </div>
      </section>

      <!-- ═══════════════════════════════════════════
           KLIEN
           ═══════════════════════════════════════════ -->
      <section
        id="klien"
        aria-label="Klien yang sudah mempercayai SukaSuka.web"
        class="py-12 border-y border-[var(--color-border-soft)] bg-[var(--color-bg-secondary)] overflow-hidden"
      >
        <div class="container mb-5 text-center reveal">
          <p
            class="font-mono text-[var(--text-xs)] text-[var(--color-text-subtle)] tracking-widest uppercase"
          >
            Dipercaya Klien dari Berbagai Sektor
          </p>
        </div>
        <div class="marquee-outer" aria-hidden="true">
          <div class="marquee-inner" id="clientMarquee">
            <div class="client-logo">MADRASAH ALIYAH TARBIYAH ISLAMIYAH</div>
            <div class="client-logo">PT. REONCY INDO ABADI</div>
            <div class="client-logo">MADRASAH ALIYAH TARBIYAH ISLAMIYAH</div>
            <div class="client-logo">PT. REONCY INDO ABADI</div>
            <div class="client-logo">MADRASAH ALIYAH TARBIYAH ISLAMIYAH</div>
            <div class="client-logo">PT. REONCY INDO ABADI</div>
          </div>
        </div>
      </section>

      <!-- ═══════════════════════════════════════════
           TENTANG
           ═══════════════════════════════════════════ -->
      <section
        id="tentang"
        class="section bg-[#f3eeea]"
        aria-labelledby="about-heading"
      >
        <div class="container">
          <div class="about-grid">
            <div class="about-visual reveal">
              <div class="relative overflow-hidden rounded-full">
                <div class="about-frame-deco" aria-hidden="true"></div>
                <img
                  src="/images/tim.jpeg"
                  alt="Tim SukaSuka.web — developer dan desainer software house Indonesia"
                  width="480"
                  height="600"
                  loading="lazy"
                />
                <!-- <div class="about-badge" aria-live="polite">
                  <span class="status-dot" aria-hidden="true"></span>
                  <span>Tim Penanggung Jawab</span>
                </div> -->
              </div>
            </div>

            <div>
              <p class="section-tag reveal">Tentang Kami</p>
              <h2 id="about-heading" class="reveal delay-1 mb-6">
                Tim Developer Muda<br />
                dengan
                <em
                  style="
                    font-family: var(--font-serif);
                    font-style: italic;
                    color: var(--color-text-brand);
                  "
                >
                  Semangat Tinggi
                </em>
              </h2>
              <p
                class="text-[var(--color-text-muted)] leading-relaxed mb-5 reveal delay-2"
              >
                <strong class="text-[var(--color-text)]">SukaSuka.web</strong>
                adalah tim developer dan desainer muda berbasis di Indonesia
                yang percaya website bagus seharusnya
                <strong class="text-[var(--color-text)]"
                  >bisa diakses semua bisnis</strong
                >, bukan hanya perusahaan besar. Kami spesialis membangun produk
                digital modern — mulai dari
                <strong class="text-[var(--color-text)]"
                  >web app, landing page, company profile</strong
                >, hingga
                <strong class="text-[var(--color-text)]"
                  >sistem kasir (POS)</strong
                >
                — dengan tech stack terkini dan harga UMKM-friendly.
              </p>

              <!-- VALUE PROPOSITION — menggantikan statistik yang tidak akurat -->
              <div
                class="about-stats reveal delay-3"
                aria-label="Keunggulan SukaSuka.web"
              >
                <div class="about-stat">
                  <span class="about-stat-num about-stat-text">Node.js</span>
                  <span class="about-stat-label">Tech Stack Modern</span>
                </div>
                <div class="about-stat-divider" aria-hidden="true"></div>
                <div class="about-stat">
                  <span class="about-stat-num about-stat-text"
                    >&lt; 24 Jam</span
                  >
                  <span class="about-stat-label">Respon WhatsApp</span>
                </div>
                <div class="about-stat-divider" aria-hidden="true"></div>
                <div class="about-stat">
                  <span class="about-stat-num about-stat-text">DP 50%</span>
                  <span class="about-stat-label">Bayar Setelah Jadi</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ═══════════════════════════════════════════
           KENAPA KAMI — Diferensiasi jujur
           ═══════════════════════════════════════════ -->
      <section
        id="kenapa"
        class="section bg-[var(--color-bg-secondary)]"
        aria-labelledby="kenapa-heading"
      >
        <div class="container">
          <div class="text-center mb-14 reveal">
            <p class="section-tag justify-center">Kenapa Kami?</p>
            <h2 id="kenapa-heading" class="mb-4">
              Bukan Agency Besar,<br />tapi
              <em
                style="
                  font-family: var(--font-serif);
                  font-style: italic;
                  color: var(--color-text-brand);
                "
                >Lebih Personal</em
              >
            </h2>
            <p class="text-[var(--color-text-muted)] max-w-xl mx-auto">
              Kami tim kecil yang fokus — artinya kamu bicara langsung dengan
              developernya, bukan admin. Proses lebih cepat, komunikasi lebih
              jelas.
            </p>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-6">
            <article class="card reveal delay-1" aria-labelledby="nilai-1">
              <div class="text-3xl mb-4" aria-hidden="true">⚡</div>
              <h3 id="nilai-1" class="text-lg font-bold mb-2">
                Tech Stack Modern
              </h3>
              <p class="text-[var(--color-text-muted)] text-sm leading-relaxed">
                Kami pakai Node.js, Laravel Livewire, dan Tailwind — bukan
                template lama. Website kamu cepat, ringan, dan mudah
                dikembangkan.
              </p>
            </article>

            <article class="card reveal delay-2" aria-labelledby="nilai-2">
              <div class="text-3xl mb-4" aria-hidden="true">💬</div>
              <h3 id="nilai-2" class="text-lg font-bold mb-2">
                Bicara Langsung ke Developer
              </h3>
              <p class="text-[var(--color-text-muted)] text-sm leading-relaxed">
                Tidak ada perantara. Kamu ngobrol langsung dengan yang ngerjain
                — lebih cepat, lebih akurat, lebih transparan.
              </p>
            </article>

            <article class="card reveal delay-3" aria-labelledby="nilai-3">
              <div class="text-3xl mb-4" aria-hidden="true">💸</div>
              <h3 id="nilai-3" class="text-lg font-bold mb-2">
                Harga UMKM-Friendly
              </h3>
              <p class="text-[var(--color-text-muted)] text-sm leading-relaxed">
                Tanpa overhead agency besar. Harga lebih kompetitif dengan
                kualitas desain dan kode yang tidak kalah profesional.
              </p>
            </article>

            <article class="card reveal delay-4" aria-labelledby="nilai-4">
              <div class="text-3xl mb-4" aria-hidden="true">🛡️</div>
              <h3 id="nilai-4" class="text-lg font-bold mb-2">
                Transparan & Aman
              </h3>
              <p class="text-[var(--color-text-muted)] text-sm leading-relaxed">
                Sistem DP 50% — kamu bayar lunas hanya setelah website selesai
                dan disetujui. Tidak ada risiko kabur.
              </p>
            </article>
          </div>
        </div>
      </section>

      <!-- ═══════════════════════════════════════════
           LAYANAN
           ═══════════════════════════════════════════ -->
      <section id="layanan" class="section" aria-labelledby="layanan-heading">
        <div class="container">
          <div class="text-center mb-14 reveal">
            <p class="section-tag justify-center">Layanan Kami</p>
            <h2 id="layanan-heading" class="mb-4">
              Solusi Digital Lengkap<br />untuk Bisnis Anda
            </h2>
            <p class="text-[var(--color-text-muted)] max-w-xl mx-auto">
              Dari landing page sederhana hingga sistem kompleks — kami kerjakan
              dengan standar kode profesional dan desain modern.
            </p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6">
            <article
              class="card reveal delay-1"
              aria-labelledby="layanan-webapp"
            >
              <div class="text-3xl mb-4" aria-hidden="true">🖥️</div>
              <h3 id="layanan-webapp" class="text-xl font-bold mb-2">
                Custom Web App
              </h3>
              <p class="text-[var(--color-text-muted)] text-sm leading-relaxed">
                Aplikasi web custom sesuai proses bisnis Anda — dashboard,
                manajemen data, portal klien, dan lebih banyak lagi.
              </p>
            </article>

            <article
              class="card reveal delay-2"
              aria-labelledby="layanan-landing"
            >
              <div class="text-3xl mb-4" aria-hidden="true">🚀</div>
              <h3 id="layanan-landing" class="text-xl font-bold mb-2">
                Landing Page
              </h3>
              <p class="text-[var(--color-text-muted)] text-sm leading-relaxed">
                Halaman marketing berkecepatan tinggi yang dioptimasi untuk
                konversi dan SEO — tampil di halaman 1 Google.
              </p>
            </article>

            <article
              class="card reveal delay-3"
              aria-labelledby="layanan-kasir"
            >
              <div class="text-3xl mb-4" aria-hidden="true">🧾</div>
              <h3 id="layanan-kasir" class="text-xl font-bold mb-2">
                Sistem Kasir (POS)
              </h3>
              <p class="text-[var(--color-text-muted)] text-sm leading-relaxed">
                Sistem point-of-sale berbasis web — manajemen stok, laporan
                penjualan, dan integrasi QRIS / payment gateway.
              </p>
            </article>

            <article
              class="card reveal delay-4"
              aria-labelledby="layanan-maintenance"
            >
              <div class="text-3xl mb-4" aria-hidden="true">🔧</div>
              <h3 id="layanan-maintenance" class="text-xl font-bold mb-2">
                Maintenance & Support
              </h3>
              <p class="text-[var(--color-text-muted)] text-sm leading-relaxed">
                Perawatan rutin, update fitur, backup berkala, dan support
                teknis untuk menjaga website tetap cepat dan aman.
              </p>
            </article>
          </div>
        </div>
      </section>

      <!-- ═══════════════════════════════════════════
           PORTOFOLIO
           ═══════════════════════════════════════════ -->
      <section
        id="portofolio"
        class="section bg-[var(--color-bg-secondary)]"
        aria-labelledby="porto-heading"
      >
        <div class="container">
          <div
            class="flex flex-col md:flex-row justify-between items-end mb-14 gap-6"
          >
            <div>
              <p class="section-tag reveal">Karya Kami</p>
              <h2 id="porto-heading" class="reveal delay-1">
                Proyek Profesional
              </h2>
            </div>
            <span class="badge badge-neutral reveal delay-2"
              >More coming soon</span
            >
          </div>

          <div class="porto-grid">
            <article
              class="porto-card reveal delay-1"
              role="button"
              tabindex="0"
              aria-label="Lihat detail proyek Reoncy"
              onclick="
                openModal({
                  img: '/images/porto-reoncy.jpg',
                  title: 'Reoncy — Modern Web App',
                  desc: 'Project website modern yang dibangun menggunakan teknologi Next.js dan React.js. Dioptimasi secara penuh untuk performa tinggi, kecepatan loading maksimal, dan pengalaman pengguna (UI/UX) yang responsif.',
                  tags: ['Live Project', 'Next.js', 'React.js'],
                  link: 'https://www.reoncy.com/',
                })
              "
            >
              <div class="porto-img-wrap">
                <img
                  src="/images/porto-reoncy.jpg"
                  alt="Screenshot website Reoncy — dibangun dengan Node.js dan Laravel Livewire.js"
                  class="porto-img"
                  width="600"
                  height="338"
                  loading="lazy"
                  onerror="
                    this.style.display = 'none';
                    this.nextElementSibling.style.display = 'flex';
                  "
                />
                <div class="porto-img-placeholder" aria-hidden="true">
                  <span>🖼️</span>
                  <p>Upload Screenshot</p>
                  <small>/images/porto-reoncy.jpg</small>
                </div>
                <div class="porto-overlay" aria-hidden="true">
                  <span class="btn btn-primary btn-sm">Lihat Detail</span>
                </div>
              </div>
              <div class="porto-info">
                <div class="flex gap-2 flex-wrap mb-3">
                  <span class="badge badge-brand">Live Project</span>
                  <span class="badge badge-neutral">Next.js</span>
                  <span class="badge badge-neutral">React.js</span>
                </div>
                <h3 class="text-xl porto-title">Reoncy</h3>
                <p
                  class="text-sm text-[var(--color-text-muted)] mt-2 leading-relaxed"
                >
                  Website berkecepatan tinggi yang dikembangkan menggunakan
                  ekosistem Node.js dan Laravel Livewire.js.
                </p>
              </div>
            </article>

            <article
              class="porto-card reveal delay-2"
              role="button"
              tabindex="0"
              aria-label="Lihat detail proyek Website MA Tarbiyah Islamiyah"
              onclick="
                openModal({
                  img: '/images/porto-matarbiyah.jpg',
                  title: 'Website MA Tarbiyah Islamiyah',
                  desc: 'Website portal informasi resmi Madrasah Aliyah Tarbiyah Islamiyah Benda, Tangerang. Dibangun dengan desain yang profesional dan responsif untuk menyajikan informasi profil, fasilitas, ekstrakurikuler, berita madrasah, hingga galeri kegiatan sekolah secara digital.',
                  tags: ['Live Project', 'Company Profile', 'Website Sekolah'],
                  link: 'https://matarbiyahbenda.sch.id/',
                })
              "
            >
              <div class="porto-img-wrap">
                <img
                  src="/images/porto-matarbiyah.jpg"
                  alt="Screenshot website sekolah MA Tarbiyah Islamiyah Benda buatan SukaSuka.web"
                  class="porto-img"
                  width="600"
                  height="338"
                  loading="lazy"
                  onerror="
                    this.style.display = 'none';
                    this.nextElementSibling.style.display = 'flex';
                  "
                />
                <div class="porto-img-placeholder" aria-hidden="true">
                  <span>🖼️</span>
                  <p>Upload Screenshot</p>
                  <small>/images/porto-matarbiyah.jpg</small>
                </div>
                <div class="porto-overlay" aria-hidden="true">
                  <span class="btn btn-primary btn-sm">Lihat Detail</span>
                </div>
              </div>
              <div class="porto-info">
                <div class="flex gap-2 flex-wrap mb-3">
                  <span class="badge badge-brand">Live Project</span>
                  <span class="badge badge-neutral">Company Profile</span>
                </div>
                <h3 class="text-xl porto-title">Website Profil Sekolah</h3>
                <p
                  class="text-sm text-[var(--color-text-muted)] mt-2 leading-relaxed"
                >
                  Portal informasi resmi madrasah dengan antarmuka modern, fitur
                  berita, dan navigasi yang mudah digunakan.
                </p>
              </div>
            </article>
          </div>
        </div>
      </section>

      <!-- ═══════════════════════════════════════════
     PAKET HARGA
     ═══════════════════════════════════════════ -->
      <section id="paket" class="section" aria-labelledby="paket-heading">
        <div class="container max-w-[1400px]">
          <div class="text-center mb-16 reveal">
            <p class="section-tag justify-center">Harga & Layanan</p>
            <h2 id="paket-heading" class="mb-4">
              Paket Pembuatan Website<br />Sesuai Kebutuhan Bisnis Anda
            </h2>
            <p class="text-[var(--color-text-muted)] max-w-2xl mx-auto">
              Dari landing page praktis untuk UMKM, hingga kemitraan retainer
              jangka panjang — semua dengan harga yang masuk akal.
            </p>
            <!-- Label harga intro -->
            <div
              class="inline-flex items-center gap-2 mt-5 px-4 py-2 rounded-full bg-[var(--color-warning-soft)] border border-[var(--color-warning)] text-[var(--color-warning)] text-xs font-mono font-semibold tracking-wide"
            >
              🎯 Harga Perkenalan — Terbatas untuk 10 Client Pertama
            </div>
          </div>

          <div
            class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6 items-stretch"
          >
            <!-- ── Paket 1 ── -->
            <article
              class="card flex flex-col h-full reveal delay-1 p-6"
              aria-labelledby="paket1-title"
            >
              <div class="mb-5">
                <span
                  class="badge badge-neutral text-[0.65rem] mb-3 inline-flex"
                  >Paling Cepat</span
                >
                <h3 id="paket1-title" class="text-xl font-bold mb-1">
                  Paket Suka-Suka 1
                </h3>
                <p class="text-[var(--color-text-muted)] text-sm paket-desc">
                  Landing page untuk UMKM, jasa perorangan, dan portofolio.
                </p>
