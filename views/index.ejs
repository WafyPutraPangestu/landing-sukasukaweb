<!DOCTYPE html>
<html lang="id">
  <head>
    <%- include('partials/head') %>

    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "LocalBusiness",
            "@id": "https://sukasukaweb.com/#business",
            "name": "SukaSuka.web",
            "alternateName": "Suka-Suka Web",
            "description": "Software house Indonesia spesialis pembuatan web app, company profile, landing page, dan sistem kasir modern untuk UMKM dan perusahaan.",
            "url": "https://sukasukaweb.com",
            "telephone": "+6285706193924",
            "email": "halo@sukasukaweb.com",
            "foundingDate": "2022",
            "areaServed": { "@type": "Country", "name": "Indonesia" },
            "serviceType": [
              "Pembuatan Website",
              "Web App Development",
              "Landing Page",
              "Company Profile",
              "Sistem Kasir POS",
              "UI/UX Design",
              "Software House"
            ],
            "priceRange": "Rp 799.000 - Negosiasi",
            "currenciesAccepted": "IDR",
            "paymentAccepted": "Bank Transfer, QRIS",
            "sameAs": [
              "https://instagram.com/sukasukaweb",
              "https://linkedin.com/company/sukasukaweb",
              "https://github.com/sukasukaweb"
            ]
          },
          {
            "@type": "WebSite",
            "@id": "https://sukasukaweb.com/#website",
            "url": "https://sukasukaweb.com",
            "name": "SukaSuka.web",
            "description": "Jasa pembuatan website profesional Indonesia",
            "inLanguage": "id-ID",
            "publisher": { "@id": "https://sukasukaweb.com/#business" }
          },
          {
            "@type": "FAQPage",
            "mainEntity": [
              {
                "@type": "Question",
                "name": "Bagaimana sistem pembayaran pembuatan website di SukaSuka.web?",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "Sistem kami mewajibkan DP 50% di awal untuk mengikat komitmen serta modal pembelian domain dan hosting. Pelunasan 50% sisanya dilakukan setelah website selesai dan siap online."
                }
              },
              {
                "@type": "Question",
                "name": "Apakah ada biaya perpanjangan tahunan untuk website?",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "Ya, ada. Biaya yang Anda bayarkan di awal sudah termasuk gratis Domain dan Hosting untuk tahun pertama. Untuk tahun kedua dan seterusnya, akan ada biaya perpanjangan server dan domain."
                }
              },
              {
                "@type": "Question",
                "name": "Berapa lama waktu pengerjaan website?",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "Paket Landing Page memakan waktu 3-7 hari kerja. Paket Bisnis 1-2 minggu, dan Paket Kustom menyesuaikan tingkat kerumitan sistem."
                }
              },
              {
                "@type": "Question",
                "name": "Apakah SukaSuka.web memberikan proposal resmi?",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "Tentu. Setelah Anda menghubungi kami via WhatsApp, kami akan mengirimkan format penawaran (proposal) ringkas namun profesional yang mencakup keuntungan, detail paket, dan langkah kerja."
                }
              }
            ]
          }
        ]
      }
    </script>
  </head>

  <body class="flex flex-col min-h-screen overflow-x-hidden w-full">
    <!-- ── CUSTOM CURSOR ── -->
    <div class="custom-cursor" id="customCursor" aria-hidden="true">
      <div class="cursor-dot"></div>
      <div class="cursor-ring"></div>
    </div>

    <%- include('partials/navbar') %>

    <main class="flex-grow" id="main-content">
      <!-- ═══════════════════════════════════════════
           HERO — Parallax + Split Text + Magnetic CTA
           ═══════════════════════════════════════════ -->
      <section
        id="beranda"
        class="hero-section relative flex items-center min-h-screen pt-28 pb-20 overflow-hidden"
        aria-labelledby="hero-heading"
      >
        <!-- Parallax layers -->
        <div class="parallax-layer" data-speed="0.15" aria-hidden="true">
          <div class="hero-blob hero-blob-1"></div>
        </div>
        <div class="parallax-layer" data-speed="0.25" aria-hidden="true">
          <div class="hero-blob hero-blob-2"></div>
        </div>
        <div class="parallax-layer" data-speed="0.1" aria-hidden="true">
          <div class="hero-blob hero-blob-3"></div>
        </div>

        <!-- Anime speed lines bg -->
        <div class="hero-speed-lines" aria-hidden="true"></div>
        <div class="hero-grid" aria-hidden="true"></div>

        <!-- Floating manga panels (decorative) -->
        <div class="manga-panel-float manga-panel-1" aria-hidden="true">
          <span class="font-mono text-xs text-[var(--color-sakura-400)]"
            >Web App ✦</span
          >
        </div>
        <div class="manga-panel-float manga-panel-2" aria-hidden="true">
          <span class="font-mono text-xs text-[var(--color-cobalt-500)]"
            >SEO Ready ◆</span
          >
        </div>
        <div class="manga-panel-float manga-panel-3" aria-hidden="true">
          <span class="font-mono text-xs text-[var(--color-success)]"
            >Node.js ▸</span
          >
        </div>

        <div class="container px-6 mx-auto relative z-10">
          <div class="max-w-4xl mx-auto text-center">
            <!-- Badge -->
            <div class="hero-badge-wrap" data-anim="fade-up" data-delay="0">
              <div
                class="inline-flex items-center gap-2 badge badge-brand mb-8"
              >
                <span class="status-dot" aria-hidden="true"></span>
                Open for Project — Indonesia
              </div>
            </div>

            <!-- Logo -->
            <div
              class="flex justify-center mb-8"
              data-anim="fade-up"
              data-delay="100"
            >
              <div class="logo-hero-wrap">
                <img
                  src="/images/logo-atas.png"
                  alt="Logo SukaSuka.web — Software House Indonesia"
                  class="h-16 w-auto mx-auto logo-hero-img"
                  width="200"
                  height="64"
                />
              </div>
            </div>

            <!-- Heading — split text animation -->
            <h1
              id="hero-heading"
              class="hero-heading mb-6"
              data-anim="fade-up"
              data-delay="200"
            >
              <span class="hero-line">Jasa Pembuatan Website</span><br />
              <span class="hero-line"
                >Profesional <em class="hero-italic">Modern</em> untuk</span
              ><br />
              <span class="hero-line text-gradient">Bisnis Indonesia</span>
            </h1>

            <p
              class="text-lg md:text-xl text-[var(--color-text-muted)] mb-10 text-balance max-w-2xl mx-auto leading-relaxed"
              data-anim="fade-up"
              data-delay="350"
            >
              Kami bantu
              <strong class="text-[var(--color-text)]"
                >UMKM dan Perusahaan</strong
              >
              membangun Web App, Company Profile, hingga Sistem Kasir (POS) yang
              cepat, modern, dan ramah mesin pencari (SEO-ready).
            </p>

            <!-- Magnetic CTA buttons -->
            <div
              class="flex flex-col sm:flex-row gap-4 justify-center"
              data-anim="fade-up"
              data-delay="500"
            >
              <a
                href="https://wa.me/6285706193924?text=Halo%20SukaSuka.web,%20saya%20ingin%20konsultasi%20gratis%20pembuatan%20website."
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn-primary btn-lg magnetic-btn"
                aria-label="Konsultasi gratis pembuatan website via WhatsApp"
              >
                <span class="btn-inner">💬 Konsultasi Gratis</span>
              </a>
              <a
                href="#paket"
                class="btn btn-secondary btn-lg magnetic-btn"
                aria-label="Lihat paket harga pembuatan website"
              >
                <span class="btn-inner">Lihat Paket Harga →</span>
              </a>
            </div>

            <!-- Stats counter strip -->
            <div class="hero-stats" data-anim="fade-up" data-delay="650">
              <div class="hero-stat-item">
                <span class="hero-stat-num counter" data-target="100">0</span
                ><span class="hero-stat-suffix">%</span>
                <span class="hero-stat-label">Kepuasan Klien</span>
              </div>
              <div class="hero-stat-sep" aria-hidden="true"></div>
              <div class="hero-stat-item">
                <span class="hero-stat-num counter" data-target="24">0</span
                ><span class="hero-stat-suffix">jam</span>
                <span class="hero-stat-label">Respon Cepat</span>
              </div>
              <div class="hero-stat-sep" aria-hidden="true"></div>
              <div class="hero-stat-item">
                <span class="hero-stat-num counter" data-target="50">0</span
                ><span class="hero-stat-suffix">%</span>
                <span class="hero-stat-label">DP, Bayar Setelah Jadi</span>
              </div>
            </div>

            <!-- Scroll hint -->
            <div class="hero-scroll-hint" aria-hidden="true">
              <div class="scroll-line"></div>
              <span>Scroll</span>
            </div>
          </div>
        </div>
      </section>

      <!-- ═══════════════════════════════════════════
           MARQUEE KLIEN
           ═══════════════════════════════════════════ -->
      <section
        id="klien"
        aria-label="Klien yang sudah mempercayai SukaSuka.web"
        class="py-12 border-y border-[var(--color-border-soft)] bg-[var(--color-bg-secondary)] overflow-hidden"
      >
        <div class="container mb-5 text-center reveal">
          <p
            class="font-mono text-[var(--text-xs)] text-[var(--color-text-subtle)] tracking-widest uppercase"
          >
            Dipercaya Klien dari Berbagai Sektor
          </p>
        </div>
        <div class="marquee-outer" aria-hidden="true">
          <div class="marquee-inner">
            <div class="client-logo">✦ MADRASAH ALIYAH TARBIYAH ISLAMIYAH</div>
            <div class="client-logo">◆ PT. REONCY INDO ABADI</div>
            <div class="client-logo">✦ MADRASAH ALIYAH TARBIYAH ISLAMIYAH</div>
            <div class="client-logo">◆ PT. REONCY INDO ABADI</div>
            <div class="client-logo">✦ MADRASAH ALIYAH TARBIYAH ISLAMIYAH</div>
            <div class="client-logo">◆ PT. REONCY INDO ABADI</div>
            <div class="client-logo">✦ MADRASAH ALIYAH TARBIYAH ISLAMIYAH</div>
            <div class="client-logo">◆ PT. REONCY INDO ABADI</div>
          </div>
        </div>
      </section>

      <!-- ═══════════════════════════════════════════
           TENTANG — Parallax image + staggered reveal
           ═══════════════════════════════════════════ -->
      <section
        id="tentang"
        class="section about-section"
        aria-labelledby="about-heading"
      >
        <div class="container">
          <div class="about-grid">
            <!-- Visual side -->
            <div class="about-visual reveal">
              <div class="about-img-outer">
                <div class="about-frame-deco" aria-hidden="true"></div>
                <div class="about-frame-deco-br" aria-hidden="true"></div>
                <div class="about-img-inner">
                  <img
                    src="/images/tim.jpeg"
                    alt="Tim SukaSuka.web — developer dan desainer software house Indonesia"
                    width="480"
                    height="600"
                    loading="lazy"
                    class="about-img parallax-img"
                    data-parallax-speed="0.08"
                  />
                  <!-- Floating badge -->
                  <div class="about-float-badge" aria-live="polite">
                    <div
                      class="lottie-micro"
                      id="lottieCode"
                      aria-hidden="true"
                    ></div>
                    <div>
                      <p
                        class="font-mono text-xs font-bold text-[var(--color-sakura-500)]"
                      >
                        Tim Developer
                      </p>
                      <p
                        class="font-mono text-[0.6rem] text-[var(--color-text-subtle)]"
                      >
                        Dedicated & Responsive
                      </p>
                    </div>
                  </div>
                  <!-- Tech stack pill -->
                  <div class="about-tech-pill" aria-hidden="true">
                    <span>Node.js</span><span>·</span><span>Next.js</span
                    ><span>·</span><span>Laravel</span>
                  </div>
                </div>
                <!-- Manga ink dots -->
                <div class="about-dots-deco" aria-hidden="true"></div>
              </div>
            </div>

            <!-- Text side -->
            <div>
              <p class="section-tag reveal">Tentang Kami</p>
              <h2 id="about-heading" class="reveal delay-1 mb-6">
                Tim Developer Muda<br />
                dengan
                <em
                  style="
                    font-family: var(--font-serif);
                    font-style: italic;
                    color: var(--color-text-brand);
                  "
                  >Semangat Tinggi</em
                >
              </h2>
              <p
                class="text-[var(--color-text-muted)] leading-relaxed mb-5 reveal delay-2"
              >
                <strong class="text-[var(--color-text)]">SukaSuka.web</strong>
                adalah tim developer dan desainer muda berbasis di Indonesia
                yang percaya website bagus seharusnya
                <strong class="text-[var(--color-text)]"
                  >bisa diakses semua bisnis</strong
                >, bukan hanya perusahaan besar. Kami spesialis membangun produk
                digital modern — mulai dari
                <strong class="text-[var(--color-text)]"
                  >web app, landing page, company profile</strong
                >, hingga
                <strong class="text-[var(--color-text)]"
                  >sistem kasir (POS)</strong
                >
                — dengan tech stack terkini dan harga UMKM-friendly.
              </p>

              <div
                class="about-stats reveal delay-3"
                aria-label="Keunggulan SukaSuka.web"
              >
                <div class="about-stat">
                  <span class="about-stat-num about-stat-text">Node.js</span>
                  <span class="about-stat-label">Tech Stack Modern</span>
                </div>
                <div class="about-stat-divider" aria-hidden="true"></div>
                <div class="about-stat">
                  <span class="about-stat-num about-stat-text"
                    >&lt; 24 Jam</span
                  >
                  <span class="about-stat-label">Respon WhatsApp</span>
                </div>
                <div class="about-stat-divider" aria-hidden="true"></div>
                <div class="about-stat">
                  <span class="about-stat-num about-stat-text">DP 50%</span>
                  <span class="about-stat-label">Bayar Setelah Jadi</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ═══════════════════════════════════════════
           KENAPA KAMI — 3D tilt cards
           ═══════════════════════════════════════════ -->
      <section
        id="kenapa"
        class="section bg-[var(--color-bg-secondary)]"
        aria-labelledby="kenapa-heading"
      >
        <div class="container">
          <div class="text-center mb-14 reveal">
            <p class="section-tag justify-center">Kenapa Kami?</p>
            <h2 id="kenapa-heading" class="mb-4">
              Bukan Agency Besar,<br />tapi
              <em
                style="
                  font-family: var(--font-serif);
                  font-style: italic;
                  color: var(--color-text-brand);
                "
                >Lebih Personal</em
              >
            </h2>
            <p class="text-[var(--color-text-muted)] max-w-xl mx-auto">
              Kami tim kecil yang fokus — artinya kamu bicara langsung dengan
              developernya, bukan admin.
            </p>
          </div>

          <div class="kenapa-grid">
            <article
              class="card tilt-card reveal delay-1"
              aria-labelledby="nilai-1"
            >
              <div class="tilt-card-inner">
                <div class="kenapa-icon-wrap" aria-hidden="true">
                  <div class="lottie-icon" id="lottie1"></div>
                  <span class="kenapa-emoji">⚡</span>
                </div>
                <h3 id="nilai-1" class="text-lg font-bold mb-2">
                  Tech Stack Modern
                </h3>
                <p
                  class="text-[var(--color-text-muted)] text-sm leading-relaxed"
                >
                  Kami pakai Node.js, Laravel Livewire, dan Tailwind — bukan
                  template lama. Website kamu cepat, ringan, dan mudah
                  dikembangkan.
                </p>
              </div>
            </article>

            <article
              class="card tilt-card reveal delay-2"
              aria-labelledby="nilai-2"
            >
              <div class="tilt-card-inner">
                <div class="kenapa-icon-wrap" aria-hidden="true">
                  <span class="kenapa-emoji">💬</span>
                </div>
                <h3 id="nilai-2" class="text-lg font-bold mb-2">
                  Bicara Langsung ke Developer
                </h3>
                <p
                  class="text-[var(--color-text-muted)] text-sm leading-relaxed"
                >
                  Tidak ada perantara. Kamu ngobrol langsung dengan yang
                  ngerjain — lebih cepat, lebih akurat, lebih transparan.
                </p>
              </div>
            </article>

            <article
              class="card tilt-card reveal delay-3"
              aria-labelledby="nilai-3"
            >
              <div class="tilt-card-inner">
                <div class="kenapa-icon-wrap" aria-hidden="true">
                  <span class="kenapa-emoji">💸</span>
                </div>
                <h3 id="nilai-3" class="text-lg font-bold mb-2">
                  Harga UMKM-Friendly
                </h3>
                <p
                  class="text-[var(--color-text-muted)] text-sm leading-relaxed"
                >
                  Tanpa overhead agency besar. Harga lebih kompetitif dengan
                  kualitas desain dan kode yang tidak kalah profesional.
                </p>
              </div>
            </article>

            <article
              class="card tilt-card reveal delay-4"
              aria-labelledby="nilai-4"
            >
              <div class="tilt-card-inner">
                <div class="kenapa-icon-wrap" aria-hidden="true">
                  <span class="kenapa-emoji">🛡️</span>
                </div>
                <h3 id="nilai-4" class="text-lg font-bold mb-2">
                  Transparan & Aman
                </h3>
                <p
                  class="text-[var(--color-text-muted)] text-sm leading-relaxed"
                >
                  Sistem DP 50% — kamu bayar lunas hanya setelah website selesai
                  dan disetujui. Tidak ada risiko kabur.
                </p>
              </div>
            </article>
          </div>
        </div>
      </section>

      <!-- ═══════════════════════════════════════════
           LAYANAN — hover ink reveal
           ═══════════════════════════════════════════ -->
      <section
        id="layanan"
        class="section layanan-section"
        aria-labelledby="layanan-heading"
      >
        <div class="container">
          <div class="text-center mb-14 reveal">
            <p class="section-tag justify-center">Layanan Kami</p>
            <h2 id="layanan-heading" class="mb-4">
              Solusi Digital Lengkap<br />untuk Bisnis Anda
            </h2>
            <p class="text-[var(--color-text-muted)] max-w-xl mx-auto">
              Dari landing page sederhana hingga sistem kompleks — kami kerjakan
              dengan standar kode profesional dan desain modern.
            </p>
          </div>

          <div class="layanan-list">
            <article class="layanan-item reveal delay-1" aria-labelledby="l1">
              <div class="layanan-num" aria-hidden="true">01</div>
              <div class="layanan-icon" aria-hidden="true">🖥️</div>
              <div class="layanan-body">
                <h3 id="l1" class="layanan-title">Custom Web App</h3>
                <p
                  class="text-[var(--color-text-muted)] text-sm leading-relaxed"
                >
                  Aplikasi web custom sesuai proses bisnis Anda — dashboard,
                  manajemen data, portal klien, dan lebih banyak lagi.
                </p>
              </div>
              <div class="layanan-arrow" aria-hidden="true">→</div>
              <div class="layanan-ink" aria-hidden="true"></div>
            </article>

            <article class="layanan-item reveal delay-2" aria-labelledby="l2">
              <div class="layanan-num" aria-hidden="true">02</div>
              <div class="layanan-icon" aria-hidden="true">🚀</div>
              <div class="layanan-body">
                <h3 id="l2" class="layanan-title">Landing Page</h3>
                <p
                  class="text-[var(--color-text-muted)] text-sm leading-relaxed"
                >
                  Halaman marketing berkecepatan tinggi yang dioptimasi untuk
                  konversi dan SEO — tampil di halaman 1 Google.
                </p>
              </div>
              <div class="layanan-arrow" aria-hidden="true">→</div>
              <div class="layanan-ink" aria-hidden="true"></div>
            </article>

            <article class="layanan-item reveal delay-3" aria-labelledby="l3">
              <div class="layanan-num" aria-hidden="true">03</div>
              <div class="layanan-icon" aria-hidden="true">🧾</div>
              <div class="layanan-body">
                <h3 id="l3" class="layanan-title">Sistem Kasir (POS)</h3>
                <p
                  class="text-[var(--color-text-muted)] text-sm leading-relaxed"
                >
                  Sistem point-of-sale berbasis web — manajemen stok, laporan
                  penjualan, dan integrasi QRIS / payment gateway.
                </p>
              </div>
              <div class="layanan-arrow" aria-hidden="true">→</div>
              <div class="layanan-ink" aria-hidden="true"></div>
            </article>

            <article class="layanan-item reveal delay-4" aria-labelledby="l4">
              <div class="layanan-num" aria-hidden="true">04</div>
              <div class="layanan-icon" aria-hidden="true">🔧</div>
              <div class="layanan-body">
                <h3 id="l4" class="layanan-title">Maintenance & Support</h3>
                <p
                  class="text-[var(--color-text-muted)] text-sm leading-relaxed"
                >
                  Perawatan rutin, update fitur, backup berkala, dan support
                  teknis untuk menjaga website tetap cepat dan aman.
                </p>
              </div>
              <div class="layanan-arrow" aria-hidden="true">→</div>
              <div class="layanan-ink" aria-hidden="true"></div>
            </article>
          </div>
        </div>
      </section>

      <!-- ═══════════════════════════════════════════
           PORTOFOLIO — Scroll snap carousel
           ═══════════════════════════════════════════ -->
      <section
        id="portofolio"
        class="section bg-[var(--color-bg-secondary)]"
        aria-labelledby="porto-heading"
      >
        <div class="container">
          <div
            class="flex flex-col md:flex-row justify-between items-end mb-14 gap-6"
          >
            <div>
              <p class="section-tag reveal">Karya Kami</p>
              <h2 id="porto-heading" class="reveal delay-1">
                Proyek Profesional
              </h2>
            </div>
            <span class="badge badge-neutral reveal delay-2"
              >More coming soon</span
            >
          </div>

          <div class="porto-grid">
            <article
              class="porto-card reveal delay-1"
              role="button"
              tabindex="0"
              aria-label="Lihat detail proyek Reoncy"
              onclick="
                openModal({
                  img: '/images/porto-reoncy.jpg',
                  title: 'Reoncy — Modern Web App',
                  desc: 'Project website modern yang dibangun menggunakan teknologi Next.js dan React.js. Dioptimasi secara penuh untuk performa tinggi, kecepatan loading maksimal, dan pengalaman pengguna (UI/UX) yang responsif.',
                  tags: ['Live Project', 'Next.js', 'React.js'],
                  link: 'https://www.reoncy.com/',
                })
              "
            >
              <div class="porto-img-wrap">
                <img
                  src="/images/porto-reoncy.jpg"
                  alt="Screenshot website Reoncy"
                  class="porto-img"
                  width="600"
                  height="338"
                  loading="lazy"
                  onerror="
                    this.style.display = 'none';
                    this.nextElementSibling.style.display = 'flex';
