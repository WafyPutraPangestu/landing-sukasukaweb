          cy="16"
          r="8"
          stroke="var(--ink)"
          stroke-width="2"
          fill="none"
        />
        <line
          x1="16"
          y1="0"
          x2="16"
          y2="10"
          stroke="var(--ink)"
          stroke-width="2"
        />
        <line
          x1="16"
          y1="22"
          x2="16"
          y2="32"
          stroke="var(--ink)"
          stroke-width="2"
        />
        <line
          x1="0"
          y1="16"
          x2="10"
          y2="16"
          stroke="var(--ink)"
          stroke-width="2"
        />
        <line
          x1="22"
          y1="16"
          x2="32"
          y2="16"
          stroke="var(--ink)"
          stroke-width="2"
        />
