              // Simple landing page icon — rocket mini
              const body = new THREE.Mesh(
                new THREE.CylinderGeometry(0.3, 0.45, 1.5, 12),
                toonMat(PAPER),
              );
              g.add(body);
              addOutline(
                new THREE.CylinderGeometry(0.3, 0.45, 1.5, 12),
                body,
                1.04,
              );
              const nose = new THREE.Mesh(
                new THREE.ConeGeometry(0.3, 0.6, 12),
                toonMat(PINK),
              );
              nose.position.y = 1.05;
              g.add(nose);
              addOutline(new THREE.ConeGeometry(0.3, 0.6, 12), nose, 1.04);
              const window1 = new THREE.Mesh(
                new THREE.SphereGeometry(0.2, 10, 10),
                toonMat(CYAN),
              );
              window1.position.set(0.01, 0.3, 0.42);
              g.add(window1);
              [-1, 1].forEach((s) => {
                const fin = new THREE.Mesh(
                  new THREE.BoxGeometry(0.5, 0.5, 0.08),
                  toonMat(CYAN),
                );
                fin.position.set(s * 0.55, -0.4, 0);
                fin.rotation.z = s * 0.45;
                g.add(fin);
              });
              const flame = new THREE.Mesh(
                new THREE.ConeGeometry(0.22, 0.5, 12),
                new THREE.MeshToonMaterial({ color: YELLW }),
              );
              flame.position.y = -1.0;
              flame.rotation.x = Math.PI;
              g.add(flame);
            } else if (pkg === "2") {
              // Building / company profile icon
              const base = new THREE.Mesh(
                new THREE.BoxGeometry(2.2, 0.2, 1.0),
                toonMat(PAPER),
              );
              base.position.y = -1.0;
              g.add(base);
              const bldg = new THREE.Mesh(
                new THREE.BoxGeometry(1.4, 2.0, 0.9),
                toonMat(PAPER),
              );
              g.add(bldg);
              addOutline(new THREE.BoxGeometry(1.4, 2.0, 0.9), bldg, 1.04);
              // Windows
              [
                [-0.35, 0.5],
                [0.35, 0.5],
                [-0.35, -0.1],
                [0.35, -0.1],
                [-0.35, -0.7],
                [0.35, -0.7],
              ].forEach(([x, y]) => {
                const win = new THREE.Mesh(
                  new THREE.BoxGeometry(0.3, 0.3, 0.06),
                  toonMat(CYAN),
                );
                win.position.set(x, y, 0.48);
                g.add(win);
              });
              // Door
              const door = new THREE.Mesh(
                new THREE.BoxGeometry(0.35, 0.5, 0.06),
                toonMat(YELLW),
              );
              door.position.set(0, -0.75, 0.48);
              g.add(door);
              // Roof detail
              const roof = new THREE.Mesh(
                new THREE.BoxGeometry(1.6, 0.15, 1.05),
                toonMat(PINK),
              );
              roof.position.y = 1.08;
              g.add(roof);
              addOutline(new THREE.BoxGeometry(1.6, 0.15, 1.05), roof, 1.04);
            } else if (pkg === "3") {
              // Gear/cog — web app
              const gear = new THREE.Mesh(
                new THREE.CylinderGeometry(0.7, 0.7, 0.3, 24),
                toonMat(CYAN),
              );
              gear.rotation.x = Math.PI / 2;
              g.add(gear);
              addOutline(
                new THREE.CylinderGeometry(0.7, 0.7, 0.3, 24),
                gear,
                1.04,
              );
              const hole = new THREE.Mesh(
                new THREE.CylinderGeometry(0.28, 0.28, 0.4, 16),
                toonMat(PAPER),
              );
              hole.rotation.x = Math.PI / 2;
              g.add(hole);
              for (let i = 0; i < 8; i++) {
                const tooth = new THREE.Mesh(
                  new THREE.BoxGeometry(0.22, 0.35, 0.28),
                  toonMat(CYAN),
                );
                tooth.position.set(
                  Math.cos((i * Math.PI) / 4) * 0.85,
                  Math.sin((i * Math.PI) / 4) * 0.85,
                  0,
                );
                tooth.rotation.z = (i * Math.PI) / 4;
                g.add(tooth);
                addOutline(
                  new THREE.BoxGeometry(0.22, 0.35, 0.28),
                  tooth,
                  1.05,
                );
              }
              // Arrow in center
              const arrow = new THREE.Mesh(
                new THREE.ConeGeometry(0.1, 0.4, 8),
                toonMat(PINK),
              );
              arrow.position.set(0.1, 0, 0.22);
              g.add(arrow);
            } else if (pkg === "vip") {
              // Star / crown
              const crown = new THREE.Group();
              const base = new THREE.Mesh(
                new THREE.BoxGeometry(1.8, 0.4, 0.4),
                toonMat(YELLW),
              );
              base.position.y = -0.5;
              crown.add(base);
              addOutline(new THREE.BoxGeometry(1.8, 0.4, 0.4), base, 1.04);
              // Crown peaks
              const peakW = [0.12, 0.12, 0.12];
              const peakH = [1.0, 1.4, 1.0];
              const peakX = [-0.6, 0, 0.6];
              peakX.forEach((x, i) => {
                const peak = new THREE.Mesh(
                  new THREE.BoxGeometry(peakW[i], peakH[i], 0.36),
                  toonMat(YELLW),
                );
                peak.position.set(x, -0.5 + 0.2 + peakH[i] / 2, 0);
                crown.add(peak);
                addOutline(
                  new THREE.BoxGeometry(peakW[i], peakH[i], 0.36),
                  peak,
                  1.05,
                );
              });
              // Gems on peaks
              const gemColors = [PINK, CYAN, PINK];
              peakX.forEach((x, i) => {
                const gem = new THREE.Mesh(
                  new THREE.SphereGeometry(0.14, 8, 8),
                  toonMat(gemColors[i]),
                );
                gem.position.set(x, -0.5 + 0.2 + peakH[i], 0);
                crown.add(gem);
              });
              g.add(crown);
            }

            g.rotation.x = 0.2;
            g.rotation.y = -0.4;

            let t = Math.random() * Math.PI * 2;
            function animate() {
              requestAnimationFrame(animate);
              t += 0.018;
              g.rotation.y = -0.4 + Math.sin(t * 0.6) * 0.25;
              g.position.y = Math.sin(t * 0.8) * 0.08;
              renderer.render(scene, camera);
            }
            animate();
          });
        }

        /* ══════════════════════════════════════
         STEP 3D — Process steps
         ══════════════════════════════════════ */
        function initStep3D() {
          document.querySelectorAll(".step-3d-canvas").forEach((canvas) => {
            const step = parseInt(canvas.dataset.step);
            const renderer = mkRenderer(canvas, 100, 80);
            const scene = new THREE.Scene();
            const camera = mkCamera(42, 0.1, 50, [0, 0, 4]);

            scene.add(new THREE.AmbientLight(0xffffff, 0.8));
            const dl = new THREE.DirectionalLight(0xffffff, 1);
            dl.position.set(2, 3, 3);
            scene.add(dl);

            const g = new THREE.Group();
            scene.add(g);

            if (step === 1) {
              // Handshake / chat icon — two speech bubbles
              const b1 = new THREE.Mesh(
                new THREE.CylinderGeometry(0.55, 0.55, 0.22, 16),
                toonMat(PINK),
              );
              b1.rotation.x = Math.PI / 2;
              b1.position.set(-0.3, 0.2, 0);
              g.add(b1);
              addOutline(
                new THREE.CylinderGeometry(0.55, 0.55, 0.22, 16),
                b1,
                1.05,
              );
              const b2 = new THREE.Mesh(
                new THREE.CylinderGeometry(0.45, 0.45, 0.18, 16),
                toonMat(CYAN),
              );
              b2.rotation.x = Math.PI / 2;
              b2.position.set(0.3, -0.3, 0);
              g.add(b2);
              addOutline(
                new THREE.CylinderGeometry(0.45, 0.45, 0.18, 16),
                b2,
                1.05,
              );
              [-0.55, -0.3, -0.05].forEach((x) => {
                const d = new THREE.Mesh(
                  new THREE.SphereGeometry(0.08, 8, 8),
                  toonMat(WHITE),
                );
                d.position.set(x, 0.2, 0.14);
                g.add(d);
              });
            } else if (step === 2) {
              // Coin / payment
              const coin = new THREE.Mesh(
                new THREE.CylinderGeometry(0.75, 0.75, 0.22, 24),
                toonMat(YELLW),
              );
              coin.rotation.x = Math.PI / 2;
              g.add(coin);
              addOutline(
                new THREE.CylinderGeometry(0.75, 0.75, 0.22, 24),
                coin,
                1.04,
              );
              const ring = new THREE.Mesh(
                new THREE.TorusGeometry(0.5, 0.06, 8, 24),
                toonMat(INK),
              );
              ring.rotation.x = Math.PI / 2;
              g.add(ring);
              // Rp symbol (two boxes)
              const r1 = new THREE.Mesh(
                new THREE.BoxGeometry(0.12, 0.7, 0.06),
                toonMat(INK),
              );
              r1.position.x = -0.1;
              g.add(r1);
              const r2 = new THREE.Mesh(
                new THREE.BoxGeometry(0.4, 0.12, 0.06),
                toonMat(INK),
              );
              r2.position.set(0.12, 0.15, 0);
              g.add(r2);
              const r3 = new THREE.Mesh(
                new THREE.BoxGeometry(0.4, 0.12, 0.06),
                toonMat(INK),
              );
              r3.position.set(0.12, -0.05, 0);
              g.add(r3);
            } else if (step === 3) {
              // Code/laptop icon
              const screen = new THREE.Mesh(
                new THREE.BoxGeometry(1.6, 1.1, 0.12),
                toonMat(INK),
              );
              g.add(screen);
              addOutline(new THREE.BoxGeometry(1.6, 1.1, 0.12), screen, 1.04);
              const surf = new THREE.Mesh(
                new THREE.BoxGeometry(1.4, 0.9, 0.08),
                toonMat(WHITE),
              );
              surf.position.z = 0.06;
              g.add(surf);
              // Code lines
              [
                [PINK, 0.9, 0.28],
                [CYAN, 1.1, 0.12],
                [PINK, 0.6, -0.04],
                [CYAN, 0.8, -0.2],
              ].forEach(([c, w, y]) => {
                const l = new THREE.Mesh(
                  new THREE.BoxGeometry(w, 0.08, 0.04),
                  new THREE.MeshToonMaterial({ color: c }),
                );
                l.position.set(0, y - 0.1, 0.12);
                g.add(l);
              });
              const cursor = new THREE.Mesh(
                new THREE.BoxGeometry(0.05, 0.12, 0.04),
                toonMat(PINK),
              );
              cursor.position.set(0.5, -0.18, 0.12);
              g.add(cursor);
              const base = new THREE.Mesh(
                new THREE.BoxGeometry(1.8, 0.18, 0.9),
                toonMat(PAPER),
              );
              base.position.y = -0.64;
              g.add(base);
              addOutline(new THREE.BoxGeometry(1.8, 0.18, 0.9), base, 1.04);
            } else if (step === 4) {
              // Rocket launch
              const body = new THREE.Mesh(
                new THREE.CylinderGeometry(0.28, 0.38, 1.4, 12),
                toonMat(WHITE),
              );
              g.add(body);
              addOutline(
                new THREE.CylinderGeometry(0.28, 0.38, 1.4, 12),
                body,
                1.04,
              );
              const nose = new THREE.Mesh(
                new THREE.ConeGeometry(0.28, 0.55, 12),
                toonMat(PINK),
              );
              nose.position.y = 0.97;
              g.add(nose);
              addOutline(new THREE.ConeGeometry(0.28, 0.55, 12), nose, 1.04);
              [-1, 1].forEach((s) => {
                const fin = new THREE.Mesh(
                  new THREE.BoxGeometry(0.42, 0.45, 0.08),
                  toonMat(CYAN),
                );
                fin.position.set(s * 0.5, -0.38, 0);
                fin.rotation.z = s * 0.42;
                g.add(fin);
              });
              const f1 = new THREE.Mesh(
                new THREE.ConeGeometry(0.2, 0.45, 12),
                new THREE.MeshToonMaterial({ color: YELLW }),
              );
              f1.position.y = -0.92;
              f1.rotation.x = Math.PI;
              g.add(f1);
              // Stars / sparkles
              [
                [0.9, 0.8],
                [1.1, -0.2],
                [-1.0, 0.4],
              ].forEach(([x, y]) => {
                const s = new THREE.Mesh(
                  new THREE.SphereGeometry(0.09, 6, 6),
                  toonMat(YELLW),
                );
                s.position.set(x, y, 0);
                g.add(s);
              });
            }

            g.rotation.x = 0.15;
            g.rotation.y = 0.2;

            let t = step * 0.5;
            function animate() {
              requestAnimationFrame(animate);
              t += 0.015;
              g.rotation.y = 0.2 + Math.sin(t * 0.7) * 0.2;
              g.position.y = Math.sin(t) * 0.05;
              renderer.render(scene, camera);
            }
            animate();
          });
        }

        /* ══ INIT ALL 3D ON DOM READY ══ */
        document.addEventListener("DOMContentLoaded", () => {
          if (window.THREE) {
            initHero3D();
            initPanelIcons();
            initLayanan3D();
            initPaket3D();
            initStep3D();
          }
        });
      })();
    </script>

    <!-- ══════════════════════════════════════════════════════════
         UI SCRIPTS (cursor, scroll, etc.)
         ══════════════════════════════════════════════════════════ -->
    <script>
      (function () {
        "use strict";

        /* ═══ INK CURSOR ═══ */
        const inkCursor = document.getElementById("inkCursor");
        if (inkCursor && window.matchMedia("(pointer:fine)").matches) {
          document.addEventListener("mousemove", (e) => {
            inkCursor.style.transform = `translate(${e.clientX}px,${e.clientY}px) translate(-50%,-50%)`;
          });
          const hoverEls = document.querySelectorAll(
            "a,button,.tilt-card,.porto-panel,.layanan-row,.faq-comic-q,.siap-item",
          );
          hoverEls.forEach((el) => {
            el.addEventListener("mouseenter", () =>
              inkCursor.classList.add("cursor-hover"),
            );
            el.addEventListener("mouseleave", () =>
              inkCursor.classList.remove("cursor-hover"),
            );
          });
          document.addEventListener("click", (e) => {
            const s = document.createElement("div");
            s.style.cssText = `position:fixed;top:${e.clientY}px;left:${e.clientX}px;width:20px;height:20px;border-radius:50%;background:var(--pink);opacity:.6;transform:translate(-50%,-50%) scale(0);pointer-events:none;z-index:9998;animation:inkSplat .4s var(--ease-bounce) forwards;`;
            document.body.appendChild(s);
            setTimeout(() => s.remove(), 400);
          });
        }

        /* ═══ DATA-ANIM stagger ═══ */
        document.addEventListener("DOMContentLoaded", () => {
          document.querySelectorAll("[data-anim]").forEach((el) => {
            const d = parseInt(el.dataset.delay || 0);
            setTimeout(() => el.classList.add("anim-visible"), d + 120);
          });
        });

        /* ═══ SCROLL REVEAL ═══ */
        document.addEventListener("DOMContentLoaded", () => {
          const io = new IntersectionObserver(
            (entries) => {
              entries.forEach((entry) => {
                if (!entry.isIntersecting) return;
                entry.target.classList.add("visible");
                io.unobserve(entry.target);
              });
            },
            { threshold: 0.08, rootMargin: "0px 0px -32px 0px" },
          );
          document.querySelectorAll(".reveal").forEach((el) => io.observe(el));
        });

        /* ═══ PROGRESS BARS ═══ */
        document.addEventListener("DOMContentLoaded", () => {
          const bObs = new IntersectionObserver(
            (entries) => {
              entries.forEach((entry) => {
                if (!entry.isIntersecting) return;
                entry.target
                  .querySelectorAll(".progress-fill[data-width]")
                  .forEach((bar) => {
                    setTimeout(() => {
                      bar.style.transition = "width 1.2s var(--ease-spring)";
                      bar.style.width = bar.dataset.width + "%";
                    }, 300);
                  });
                bObs.unobserve(entry.target);
              });
            },
            { threshold: 0.3 },
          );
          const stats = document.querySelector(".hero-stats-comic");
          if (stats) bObs.observe(stats);
        });

        /* ═══ COUNTER ═══ */
        function animCounter(el) {
          const target = parseInt(el.dataset.target);
          const start = performance.now();
          const dur = 1600;
          function tick(now) {
            const p = Math.min((now - start) / dur, 1);
            const e = p === 1 ? 1 : 1 - Math.pow(2, -10 * p);
            el.textContent = Math.floor(e * target);
            if (p < 1) requestAnimationFrame(tick);
            else el.textContent = target;
          }
          requestAnimationFrame(tick);
        }
        const cObs = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (!e.isIntersecting) return;
              animCounter(e.target);
              cObs.unobserve(e.target);
            });
          },
          { threshold: 0.5 },
        );
        document.querySelectorAll(".counter").forEach((el) => cObs.observe(el));

        /* ═══ TILT CARDS ═══ */
        document.querySelectorAll(".tilt-card").forEach((card) => {
          card.addEventListener("mousemove", (e) => {
            const r = card.getBoundingClientRect();
            const rx =
              ((e.clientY - r.top - r.height / 2) / (r.height / 2)) * -8;
            const ry = ((e.clientX - r.left - r.width / 2) / (r.width / 2)) * 8;
            card.style.transform = `perspective(700px) rotateX(${rx}deg) rotateY(${ry}deg) translateZ(6px)`;
          });
          card.addEventListener("mouseleave", () => {
            card.style.transition = "transform .5s var(--ease-spring)";
            card.style.transform =
              "perspective(700px) rotateX(0) rotateY(0) translateZ(0)";
          });
          card.addEventListener("mouseenter", () => {
            card.style.transition = "transform .1s linear";
          });
        });

        /* ═══ MAGNETIC BUTTONS ═══ */
        document.querySelectorAll(".magnetic-btn").forEach((btn) => {
          btn.addEventListener("mousemove", (e) => {
            const r = btn.getBoundingClientRect();
            btn.style.transform = `translate(${(e.clientX - r.left - r.width / 2) * 0.22}px,${(e.clientY - r.top - r.height / 2) * 0.22}px)`;
          });
          btn.addEventListener("mouseleave", () => {
            btn.style.transition = "transform .45s var(--ease-spring)";
            btn.style.transform = "";
          });
          btn.addEventListener("mouseenter", () => {
            btn.style.transition = "transform .08s linear";
          });
        });

        /* ═══ CHECKLIST STAGGER ═══ */
        const clObs = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              entry.target
                .querySelectorAll(".checklist-item")
                .forEach((item, i) =>
                  setTimeout(() => item.classList.add("in-view"), i * 90),
                );
              clObs.unobserve(entry.target);
            });
          },
          { threshold: 0.1 },
        );
        document
          .querySelectorAll(".siap-list")
          .forEach((ol) => clObs.observe(ol));

        /* ═══ NAVBAR SCROLL ═══ */
        const navbar = document.querySelector(".navbar");
        if (navbar)
          window.addEventListener(
            "scroll",
            () => navbar.classList.toggle("scrolled", window.scrollY > 30),
            { passive: true },
          );

        /* ═══ MODAL ═══ */
        const modalEl = document.getElementById("projectModal");
        const mImg = document.getElementById("modalImage");
        const mImgPh = document.getElementById("modalImgPh");
        const mTitle = document.getElementById("modalTitle");
        const mDesc = document.getElementById("modalDesc");
        const mTags = document.getElementById("modalTags");
        const mLink = document.getElementById("modalLink");

        window.openModal = function ({
          img,
          title,
          desc,
          tags = [],
          link = "#",
        }) {
          mImg.src = img;
          mImg.alt = title;
          mImg.style.display = "block";
          mImgPh.style.display = "none";
          mImg.onerror = () => {
            mImg.style.display = "none";
            mImgPh.style.display = "flex";
          };
          mTitle.textContent = title;
          mDesc.textContent = desc;
          mLink.href = link;
          mTags.innerHTML = tags
            .map((t) => `<span class="badge badge-dark">${t}</span>`)
            .join("");
          modalEl.removeAttribute("hidden");
          document.body.style.overflow = "hidden";
          requestAnimationFrame(() => modalEl.classList.add("modal-open"));
        };
        window.closeModal = function () {
          modalEl.classList.remove("modal-open");
          document.body.style.overflow = "";
          setTimeout(() => modalEl.setAttribute("hidden", ""), 280);
        };
        document.addEventListener("keydown", (e) => {
          if (e.key === "Escape" && !modalEl.hasAttribute("hidden"))
            closeModal();
        });
        document.querySelectorAll(".porto-panel").forEach((card) => {
          card.addEventListener("keydown", (e) => {
            if (e.key === "Enter" || e.key === " ") {
              e.preventDefault();
              card.click();
            }
          });
        });

        /* ═══ INK SPLAT KEYFRAME ═══ */
        if (!document.getElementById("inkSplatStyle")) {
          const s = document.createElement("style");
          s.id = "inkSplatStyle";
          s.textContent =
            "@keyframes inkSplat{0%{transform:translate(-50%,-50%) scale(0);opacity:.8;}60%{transform:translate(-50%,-50%) scale(2.5);opacity:.4;}100%{transform:translate(-50%,-50%) scale(4);opacity:0;}}";
          document.head.appendChild(s);
        }
      })();
    </script>
  </body>
</html>
