    <!-- ══════════════════════════════════════════════════════════
         STYLES TAMBAHAN UNTUK ELEMEN BARU
         ══════════════════════════════════════════════════════════ -->
    <style>
      html,
      body {
        width: 100%;
        max-width: 100vw;
        overflow-x: hidden;
      }

      /* INK CURSOR */
      .ink-cursor {
        position: fixed;
        pointer-events: none;
        z-index: 9999;
        top: 0;
        left: 0;
        width: 32px;
        height: 32px;
        transform: translate(-50%, -50%);
        mix-blend-mode: multiply;
        transition: transform 0.05s linear;
      }
      .cursor-nib {
        width: 32px;
        height: 32px;
        transition: transform 0.2s var(--ease-bounce);
      }
      .ink-cursor.cursor-hover .cursor-nib {
        transform: scale(1.5) rotate(45deg);
      }
      @media (pointer: coarse) {
        .ink-cursor {
          display: none;
        }
      }

      .hero-comic {
        min-height: 100vh;
        background: var(--paper);
        border-bottom: var(--border-heavy);
        position: relative;
        overflow: hidden;
        padding-top: 90px;
        display: flex;
        align-items: center;
      }

      .hero-halftone-bg {
        position: absolute;
        inset: 0;
        background-image: var(--halftone-ink);
        background-size: var(--halftone-size-lg);
        opacity: 0.5;
        pointer-events: none;
      }

      .hero-speedlines {
        position: absolute;
        inset: 0;
        background-image: var(--speedlines);
        opacity: 0.6;
        pointer-events: none;
        animation: rotateSlow 90s linear infinite;
      }

      @keyframes rotateSlow {
        to {
          transform: rotate(360deg);
        }
      }

      .hero-panel-border {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 6px;
        background: var(--ink);
      }

      /* ── FLOATERS ─────────────────────────────────────────── */
      .hero-floater {
        position: absolute;
        background: var(--paper-white);
        border: var(--border-thick);
        padding: 0.45rem 1rem;
        box-shadow: var(--shadow-sm);
        z-index: 5;
        pointer-events: none;
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }
      .hero-floater-1 {
        top: 18%;
        left: 3%;
      }
      .hero-floater-2 {
        top: 60%;
        right: 3%;
      }
      .hero-floater-3 {
        bottom: 20%;
        left: 5%;
      }
      .floater-label {
        font-family: var(--font-display);
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--ink);
      }
      @media (max-width: 1024px) {
        .hero-floater {
          display: none;
        }
      }

      /* ── HERO CONTENT GRID ────────────────────────────────── */
      /* 
  FIX: Pakai grid 2-col di desktop, 1-col di mobile.
  Visual berada di kolom kanan via order.
*/
      .hero-content-wrap {
        position: relative;
        z-index: 10;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 3rem;
        align-items: center;
        padding-block: 4rem;
        width: 100%;
      }

      .hero-content {
        max-width: 580px;
      }

      /* Visual kolom kanan — tampil hanya di desktop */
      .hero-3d-wrap {
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        z-index: 8;
      }

      @media (max-width: 900px) {
        .hero-content-wrap {
          grid-template-columns: 1fr;
        }
        .hero-3d-wrap {
          display: none; /* sembunyikan visual di mobile */
        }
        .hero-content {
          max-width: 100%;
        }
      }

      /* ── VISUAL STAGE (wrapper chip + laptop) ─────────────── */
      .hero-visual-stage {
        position: relative;
        width: 420px;
        height: 360px;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      /* ── CSS 3D LAPTOP ────────────────────────────────────── */
      .css-laptop {
        position: relative;
        animation: laptopFloat 5s ease-in-out infinite;
        transform-style: preserve-3d;
        filter: drop-shadow(6px 6px 0 var(--ink));
      }

      @keyframes laptopFloat {
        0%,
        100% {
          transform: translateY(0) rotate(-2deg);
        }
        50% {
          transform: translateY(-14px) rotate(2deg);
        }
      }

      /* Screen lid */
      .laptop-screen {
        width: 260px;
        background: var(--ink);
        border: 3.5px solid var(--ink);
        border-bottom: none;
        border-radius: 6px 6px 0 0;
        padding: 8px;
        position: relative;
      }

      .laptop-bezel {
        background: var(--ink);
        border-radius: 4px 4px 0 0;
        padding: 24px 10px 10px;
        position: relative;
      }

      /* Browser chrome dots di atas */
      .browser-dots {
        position: absolute;
        top: 8px;
        left: 12px;
        display: flex;
        gap: 5px;
      }
      .browser-dots span {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        border: 1.5px solid var(--ink);
        display: block;
      }

      /* Display content area */
      .laptop-display {
        background: var(--paper-white);
        border: 2px solid rgba(10, 10, 10, 0.5);
        border-radius: 2px;
        padding: 12px 14px;
        min-height: 140px;
        position: relative;
        overflow: hidden;
      }

      /* Code lines */
      .code-line {
        height: 7px;
        border-radius: 2px;
        opacity: 0.85;
      }

      /* Blinking cursor */
      .cursor-blink-block {
        width: 6px;
        height: 12px;
        background: var(--pink);
        margin-top: 8px;
        animation: cursorBlink 0.9s step-end infinite;
      }
      @keyframes cursorBlink {
        0%,
        100% {
          opacity: 1;
        }
        50% {
          opacity: 0;
        }
      }

      /* Hinge strip */
      .laptop-hinge {
        height: 5px;
        background: var(--ink);
        width: 100%;
        position: relative;
        z-index: 2;
      }

      /* Base / keyboard area */
      .laptop-base {
        width: 260px;
        background: var(--paper-cream);
        border: 3.5px solid var(--ink);
        border-top: none;
        border-radius: 0 0 8px 8px;
        padding: 12px 14px 14px;
        box-shadow: 0 8px 0 var(--ink);
      }

      /* Keyboard grid */
      .laptop-keyboard {
        display: flex;
        flex-direction: column;
        gap: 5px;
      }
      .key-row {
        display: flex;
        gap: 4px;
      }
      .key-row span {
        flex: 1;
        height: 10px;
        background: var(--paper-fold);
        border: 1.5px solid var(--ink);
        border-radius: 2px;
      }
      .key-row-space {
        justify-content: center;
      }
      .spacebar {
        flex: 0 0 55% !important;
        height: 10px;
        background: var(--paper-fold);
        border: 1.5px solid var(--ink);
        border-radius: 2px;
      }

      /* ── FLOATING CHIPS (vis-chip) ────────────────────────── */
      /*
  FIX: Sebelumnya .iso-chip posisinya ambiguous.
  Sekarang pakai .vis-chip dengan posisi yang jelas
  terhadap .hero-visual-stage (position: relative).
*/
      .vis-chip {
        position: absolute;
        background: var(--paper-white);
        border: 2.5px solid var(--ink);
        box-shadow: var(--shadow-sm);
        padding: 0.35rem 0.8rem;
        display: flex;
        align-items: center;
        gap: 0.4rem;
        font-family: var(--font-display);
        font-size: 0.68rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        white-space: nowrap;
        z-index: 10;
      }
      .chip-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        border: 1.5px solid var(--ink);
        flex-shrink: 0;
      }
      .vis-chip-1 {
        top: 8%;
        right: -8%;
        transform: rotate(2deg);
        animation: chipFloat1 4.5s ease-in-out infinite;
      }
      .vis-chip-2 {
        top: 48%;
        left: -5%;
        transform: rotate(-2deg);
        animation: chipFloat2 5s ease-in-out infinite;
      }
      .vis-chip-3 {
        bottom: 10%;
        right: -2%;
        transform: rotate(1deg);
        animation: chipFloat3 4s ease-in-out infinite;
      }

      @keyframes chipFloat1 {
        0%,
        100% {
          transform: rotate(2deg) translateY(0);
        }
        50% {
          transform: rotate(2deg) translateY(-8px);
        }
      }
      @keyframes chipFloat2 {
        0%,
        100% {
          transform: rotate(-2deg) translateY(0);
        }
        50% {
          transform: rotate(-2deg) translateY(10px);
        }
      }
      @keyframes chipFloat3 {
        0%,
        100% {
          transform: rotate(1deg) translateY(0);
        }
        50% {
          transform: rotate(1deg) translateY(-6px);
        }
      }

      /* Halftone dots decoration pojok kanan bawah */
      .vis-dots {
        position: absolute;
        bottom: 0;
        right: -10px;
        width: 80px;
        height: 80px;
        background-image: var(--halftone-pink);
        background-size: 12px 12px;
        opacity: 0.5;
        pointer-events: none;
      }

      /* ── HERO TEXT ────────────────────────────────────────── */
      .hero-badge-row {
        margin-bottom: 1.25rem;
      }
      .hero-logo-wrap {
        margin-bottom: 1rem;
      }
      .hero-logo-img {
        height: 50px;
        width: auto;
        filter: drop-shadow(1.5px 1.5px 0 var(--pink));
      }

      .hero-heading-block {
        margin-bottom: 1.5rem;
        position: relative;
      }
      .hero-h1 {
        font-family: var(--font-comic);
        font-size: clamp(3rem, 8vw, 7rem);
        line-height: 0.9;
        letter-spacing: 0.03em;
        text-transform: uppercase;
        display: flex;
        flex-direction: column;
        gap: 0.1em;
      }
      .h1-line {
        display: block;
      }
      .h1-outline {
        color: transparent;
        -webkit-text-stroke: 4px var(--ink);
        text-shadow: none;
      }
      .h1-filled {
        color: var(--paper-white);
        -webkit-text-stroke: 3px var(--ink);
        text-shadow: 6px 6px 0 var(--ink);
      }
      .h1-splash {
        color: transparent;
        background: linear-gradient(135deg, var(--pink) 0%, var(--cyan) 100%);
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-stroke: 0px;
        text-shadow: none;
        filter: drop-shadow(4px 4px 0 var(--ink));
      }

      .hero-annotation {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-top: 0.5rem;
        margin-left: 1rem;
      }
      .annot-arrow {
        width: 60px;
        height: 30px;
        flex-shrink: 0;
      }

      .hero-sub {
        font-family: var(--font-sans);
        font-size: var(--text-base);
        color: var(--color-text-muted);
        line-height: var(--leading-relaxed);
        margin-bottom: 2rem;
      }
      .hero-sub strong {
        color: var(--ink);
        font-weight: 700;
      }

      .hero-cta-row {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 2.5rem;
      }

      /* ── HERO STATS ───────────────────────────────────────── */
      .hero-stats-comic {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        max-width: 400px;
        background: var(--paper-white);
        border: var(--border-thick);
        padding: 1.25rem 1.5rem;
        box-shadow: var(--shadow-md);
      }
      .hstat-item {
        display: flex;
        align-items: center;
        gap: 0.75rem;
      }
      .hstat-label {
        font-family: var(--font-display);
        font-size: var(--text-xs);
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        width: 110px;
        flex-shrink: 0;
        color: var(--ink);
      }
      .hstat-bar-wrap {
        flex: 1;
      }
      .hstat-val {
        font-family: var(--font-comic);
        font-size: 1.1rem;
        color: var(--ink);
        text-shadow: 1px 1px 0 var(--pink);
        width: 60px;
        text-align: right;
        flex-shrink: 0;
      }

      /* ── SCROLL HINT ──────────────────────────────────────── */
      .hero-scroll-hint {
        position: absolute;
        bottom: 1.5rem;
        left: 50%;
        transform: translateX(-50%);
        z-index: 10;
      }
      .scroll-panel {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
        background: var(--ink);
        color: var(--paper-white);
        padding: 0.6rem 1rem;
        border: var(--border-thin);
        box-shadow: var(--shadow-xs);
      }
      .scroll-arrow-anim {
        display: flex;
        flex-direction: column;
        gap: 2px;
      }
      .sarrow {
        width: 12px;
        height: 6px;
        border-left: 2px solid var(--yellow);
        border-bottom: 2px solid var(--yellow);
        transform: rotate(-45deg);
        animation: scrollArrow 1.4s ease-in-out infinite;
      }
      .sarrow-2 {
        animation-delay: 0.3s;
      }
      @keyframes scrollArrow {
        0%,
        100% {
          opacity: 0.3;
          transform: rotate(-45deg) translate(0, 0);
        }
        50% {
          opacity: 1;
          transform: rotate(-45deg) translate(3px, 3px);
        }
      }
      @keyframes scrollArrow {
        0%,
        100% {
          opacity: 0.3;
          transform: rotate(-45deg) translate(0, 0);
        }
        50% {
          opacity: 1;
          transform: rotate(-45deg) translate(3px, 3px);
        }
      }

      /* MARQUEE */
      .marquee-section {
        position: relative;
        background: var(--ink);
        overflow: hidden;
      }
      .rip-top {
        height: 14px;
        background: var(--paper);
        clip-path: polygon(
          0% 0%,
          2% 100%,
          4% 0%,
          6% 100%,
          8% 0%,
          10% 100%,
          12% 0%,
          14% 100%,
          16% 0%,
          18% 100%,
          20% 0%,
          22% 100%,
          24% 0%,
          26% 100%,
          28% 0%,
          30% 100%,
          32% 0%,
          34% 100%,
          36% 0%,
          38% 100%,
          40% 0%,
          42% 100%,
          44% 0%,
          46% 100%,
          48% 0%,
          50% 100%,
          52% 0%,
          54% 100%,
          56% 0%,
          58% 100%,
          60% 0%,
          62% 100%,
          64% 0%,
          66% 100%,
          68% 0%,
          70% 100%,
          72% 0%,
          74% 100%,
          76% 0%,
          78% 100%,
          80% 0%,
          82% 100%,
          84% 0%,
          86% 100%,
          88% 0%,
          90% 100%,
          92% 0%,
          94% 100%,
          96% 0%,
          98% 100%,
          100% 0%
        );
      }
      .rip-bottom {
        height: 14px;
        background: var(--paper);
        clip-path: polygon(
          0% 100%,
          2% 0%,
          4% 100%,
          6% 0%,
          8% 100%,
          10% 0%,
          12% 100%,
          14% 0%,
          16% 100%,
          18% 0%,
          20% 100%,
          22% 0%,
          24% 100%,
          26% 0%,
          28% 100%,
          30% 0%,
          32% 100%,
          34% 0%,
          36% 100%,
          38% 0%,
          40% 100%,
          42% 0%,
          44% 100%,
          46% 0%,
          48% 100%,
          50% 0%,
          52% 100%,
          54% 0%,
          56% 100%,
          58% 0%,
          60% 100%,
          62% 0%,
          64% 100%,
          66% 0%,
          68% 100%,
          70% 0%,
          72% 100%,
          74% 0%,
          76% 100%,
          78% 0%,
          80% 100%,
          82% 0%,
          84% 100%,
          86% 0%,
          88% 100%,
          90% 0%,
          92% 100%,
          94% 0%,
          96% 100%,
          98% 0%,
          100% 100%
        );
      }
      .marquee-inner-wrap {
        padding: 1.2rem 0;
        overflow: hidden;
      }
      .marquee-track {
        display: flex;
        width: max-content;
        animation: mq 28s linear infinite;
      }
      .marquee-section:hover .marquee-track {
        animation-play-state: paused;
      }
      .marquee-slide {
        display: flex;
        align-items: center;
      }
      .mq-item {
        font-family: var(--font-display);
        font-size: 1rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: var(--paper-white);
        padding: 0 1.5rem;
        white-space: nowrap;
        transition: color var(--duration-base);
      }
      .mq-item:hover {
        color: var(--yellow);
      }
      .mq-sep {
        color: var(--pink);
        font-size: 1.2rem;
        flex-shrink: 0;
      }
      @keyframes mq {
        from {
          transform: translateX(0);
        }
        to {
          transform: translateX(-50%);
        }
      }

      /* ABOUT */
      .about-section {
        background: var(--paper-cream);
      }
      .section-chapter-mark {
        margin-bottom: 1rem;
      }
      .about-panel-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 5rem;
        align-items: center;
      }
      @media (max-width: 768px) {
        .about-panel-grid {
          grid-template-columns: 1fr;
          gap: 2.5rem;
        }
      }
      .about-manga-frame {
        position: relative;
      }
      .manga-corner-tl {
        position: absolute;
        top: -14px;
        left: -14px;
        z-index: 3;
        width: 50px;
        height: 50px;
        border-top: 4px solid var(--ink);
        border-left: 4px solid var(--ink);
        pointer-events: none;
      }
      .manga-corner-tl::after {
        content: "";
        position: absolute;
        top: 6px;
        left: 6px;
        width: 20px;
        height: 20px;
        border-top: 2px solid var(--pink);
        border-left: 2px solid var(--pink);
      }
      .manga-corner-br {
        position: absolute;
        bottom: -14px;
        right: -14px;
        z-index: 3;
        width: 50px;
        height: 50px;
        border-bottom: 4px solid var(--ink);
        border-right: 4px solid var(--ink);
        pointer-events: none;
      }
      .manga-corner-br::after {
        content: "";
        position: absolute;
        bottom: 6px;
        right: 6px;
        width: 20px;
        height: 20px;
        border-bottom: 2px solid var(--cyan);
        border-right: 2px solid var(--cyan);
      }
      .about-photo-inner {
        border: var(--border-thick);
        box-shadow: var(--shadow-xl);
        overflow: hidden;
        aspect-ratio: 4/5;
        position: relative;
      }
      .about-photo {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.6s;
        filter: contrast(1.05) saturate(0.9);
      }
      .about-photo-inner:hover .about-photo {
        transform: scale(1.04);
      }
      .about-photo-halftone {
        position: absolute;
        top: 0;
        right: 0;
        width: 120px;
        height: 120px;
        background-image: var(--halftone-pink);
        background-size: 8px 8px;
        opacity: 0.35;
        pointer-events: none;
        mix-blend-mode: multiply;
      }
      .about-float-chip {
        position: absolute;
        background: var(--paper-white);
        border: var(--border-base);
        box-shadow: var(--shadow-sm);
        padding: 0.45rem 0.9rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        z-index: 5;
      }
      .chip-tl {
        top: 1rem;
        left: 1rem;
      }
      .about-float-bubble {
        position: absolute;
        bottom: 1.5rem;
        right: 1rem;
        z-index: 5;
      }
      .about-tech-row {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
        margin-top: 1.5rem;
        justify-content: center;
      }
      .about-h2 {
        font-size: clamp(2rem, 5vw, 3.5rem);
        margin-bottom: 1.5rem;
      }
      .about-p {
        font-size: var(--text-base);
        color: var(--color-text-muted);
        line-height: var(--leading-relaxed);
        margin-bottom: 1rem;
      }
      .about-p strong {
        color: var(--ink);
      }
      .about-stats-grid {
        display: flex;
        gap: 0;
        margin: 2rem 0;
        flex-wrap: wrap;
      }

      /* KENAPA */
      .kenapa-section {
        position: relative;
      }
      .kenapa-halftone-bg {
        position: absolute;
        inset: 0;
        background-color: var(--paper-cream);
        background-image: var(--halftone-ink);
        background-size: var(--halftone-size-lg);
        opacity: 0.8;
      }
      .kenapa-h2 {
        font-size: clamp(2rem, 5vw, 3.5rem);
        margin-bottom: 2rem;
      }
      .section-header-split {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        flex-wrap: wrap;
        gap: 2rem;
        margin-bottom: 3rem;
      }
      .kenapa-manga-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 0;
        border: var(--border-thick);
        box-shadow: var(--shadow-xl);
      }
      @media (min-width: 900px) {
        .kenapa-manga-grid {
          grid-template-columns: repeat(4, 1fr);
        }
      }
      @media (max-width: 640px) {
        .kenapa-manga-grid {
          grid-template-columns: 1fr;
        }
      }
      .kenapa-panel {
        background: var(--paper-white);
        border-right: var(--border-base);
        border-bottom: var(--border-base);
        padding: 2rem 1.5rem;
        position: relative;
        overflow: hidden;
        transition:
          background var(--duration-base),
          transform var(--duration-base) var(--ease-bounce),
          box-shadow var(--duration-base);
      }
      .kenapa-panel:last-child {
        border-right: none;
      }
      .kenapa-panel-pink {
        background: var(--pink-pale);
      }
      .kenapa-panel-cyan {
        background: var(--cyan-pale);
      }
      .panel-num {
        font-family: var(--font-comic);
        font-size: 4rem;
        color: var(--ink);
        opacity: 0.06;
        position: absolute;
        top: -0.5rem;
        right: 0.5rem;
        line-height: 1;
        pointer-events: none;
        -webkit-text-stroke: 1px var(--ink);
      }
      .panel-burst {
        position: absolute;
        inset: 0;
        background: var(--speedlines);
        opacity: 0;
        transition: opacity var(--duration-base);
        pointer-events: none;
      }
      .kenapa-panel:hover .panel-burst {
        opacity: 0.7;
      }
      .panel-icon-wrap {
        margin-bottom: 1.25rem;
        position: relative;
        z-index: 2;
        height: 80px;
        display: flex;
        align-items: center;
      }
      .panel-3d-canvas {
        display: block;
      }
      .panel-emoji {
        font-size: 3rem;
        display: none;
      }
      .panel-emoji-fallback.show {
        display: block;
      }
      .panel-title {
        font-family: var(--font-comic);
        font-size: 1.5rem;
        -webkit-text-stroke: 1.5px var(--ink);
        text-shadow: 2px 2px 0 var(--ink);
        text-transform: uppercase;
        letter-spacing: 0.03em;
        line-height: 1.1;
        margin-bottom: 0.75rem;
        position: relative;
        z-index: 2;
      }
      .panel-desc {
        font-size: var(--text-sm);
        color: var(--color-text-muted);
        line-height: var(--leading-relaxed);
        position: relative;
        z-index: 2;
      }
      .panel-action-line {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 4px;
        background: var(--ink);
        transform: scaleX(0);
        transform-origin: left;
        transition: transform var(--duration-base) var(--ease-spring);
      }
      .kenapa-panel:hover .panel-action-line {
        transform: scaleX(1);
      }
      .kenapa-panel-pink:hover .panel-action-line {
        background: var(--pink);
      }
      .kenapa-panel-cyan:hover .panel-action-line {
        background: var(--cyan);
      }

      /* LAYANAN */
      .layanan-section {
        background: var(--paper);
      }
      .layanan-header {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        margin-bottom: 3rem;
      }
      .layanan-h2 {
        font-size: clamp(2rem, 5vw, 3.5rem);
      }
      .layanan-sub {
        font-size: var(--text-base);
        color: var(--color-text-muted);
        max-width: 480px;
        line-height: var(--leading-relaxed);
      }
      .layanan-manga-list {
        border: var(--border-thick);
        box-shadow: var(--shadow-xl);
        overflow: hidden;
      }
      .layanan-row {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        padding: 1.75rem 2rem;
        border-bottom: var(--border-base);
        position: relative;
        overflow: hidden;
        background: var(--paper-white);
        transition: background var(--duration-base);
      }
      .layanan-row:last-child {
        border-bottom: none;
      }
      .lyr-ink-reveal {
        position: absolute;
        inset: 0;
        background: var(--yellow);
        transform: translateX(-102%);
        transition: transform 0.4s var(--ease-spring);
        z-index: 0;
      }
      .layanan-row:hover .lyr-ink-reveal {
        transform: translateX(0);
      }
      .layanan-row > * {
        position: relative;
        z-index: 1;
      }
      .lyr-num {
        font-family: var(--font-mono);
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        color: var(--color-text-subtle);
        width: 26px;
        flex-shrink: 0;
      }
      .lyr-3d-wrap {
        width: 90px;
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .lyr-3d-canvas {
        display: block;
        transition: transform var(--duration-base) var(--ease-bounce);
      }
      .layanan-row:hover .lyr-3d-canvas {
        transform: scale(1.1) rotate(-3deg);
      }
      .lyr-body {
        flex: 1;
        min-width: 0;
      }
      .lyr-title {
        font-family: var(--font-display);
        font-size: 1.15rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: var(--ink);
        margin-bottom: 0.35rem;
        transition: color var(--duration-base);
      }
      .lyr-desc {
        font-size: var(--text-sm);
        color: var(--color-text-muted);
        line-height: var(--leading-normal);
      }
      .lyr-tags {
        display: flex;
        gap: 0.4rem;
        flex-wrap: wrap;
        flex-shrink: 0;
      }
      .lyr-arrow {
        font-family: var(--font-display);
        font-size: 1.3rem;
        color: var(--ink);
        flex-shrink: 0;
        transition: transform var(--duration-base) var(--ease-spring);
      }
      .layanan-row:hover .lyr-arrow {
        transform: translateX(6px);
      }
      @media (max-width: 640px) {
        .layanan-row {
          flex-wrap: wrap;
          padding: 1.25rem;
          gap: 0.75rem;
        }
        .lyr-arrow,
        .lyr-tags {
          display: none;
        }
      }

      /* PORTO */
      .porto-section {
        position: relative;
      }
      .porto-crosshatch {
        position: absolute;
        inset: 0;
        background-color: var(--paper-cream);
        background-image: var(--crosshatch);
      }
      .porto-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        flex-wrap: wrap;
        gap: 2rem;
        margin-bottom: 3rem;
      }
      .porto-h2 {
        font-size: clamp(2rem, 5vw, 3.5rem);
      }
      .porto-manga-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 0;
        border: var(--border-thick);
        box-shadow: var(--shadow-xl);
      }
      @media (max-width: 640px) {
        .porto-manga-grid {
          grid-template-columns: 1fr;
        }
      }
      .porto-panel {
        background: var(--paper-white);
        border-right: var(--border-base);
        cursor: pointer;
        overflow: hidden;
        position: relative;
        transition:
          transform var(--duration-slow) var(--ease-bounce),
          box-shadow var(--duration-slow);
      }
      .porto-panel:last-child {
        border-right: none;
      }
      .porto-panel:focus-visible {
        outline: 3px solid var(--pink);
        outline-offset: 2px;
      }
      .porto-panel-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1rem 1.25rem;
        border-bottom: var(--border-base);
        background: var(--paper-cream);
      }
      .porto-panel-num {
        font-family: var(--font-mono);
        font-size: 0.7rem;
        font-weight: 700;
        color: var(--color-text-subtle);
        letter-spacing: 0.12em;
      }
      .porto-img-wrap {
        position: relative;
        aspect-ratio: 16/9;
        background: var(--paper-cream);
        overflow: hidden;
      }
      .porto-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform var(--duration-slow);
        filter: saturate(0.85);
      }
      .porto-panel:hover .porto-img {
        transform: scale(1.04);
        filter: saturate(1);
      }
      .porto-img-ph {
        position: absolute;
        inset: 0;
        display: none;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        font-family: var(--font-mono);
        font-size: 0.7rem;
        color: var(--color-text-subtle);
      }
      .porto-img-ph span {
        font-size: 2rem;
      }
      .porto-ink-overlay {
        position: absolute;
        inset: 0;
        background: rgba(10, 10, 10, 0.6);
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: opacity var(--duration-base);
      }
      .porto-panel:hover .porto-ink-overlay {
        opacity: 1;
      }
      .porto-speedlines-overlay {
        position: absolute;
        inset: 0;
        background: var(--speedlines);
        opacity: 0;
        transition: opacity var(--duration-base);
        pointer-events: none;
      }
      .porto-panel:hover .porto-speedlines-overlay {
        opacity: 0.5;
      }
      .porto-panel-info {
        padding: 1.25rem;
      }
      .porto-title {
        font-family: var(--font-comic);
        font-size: 1.5rem;
        -webkit-text-stroke: 1.5px var(--ink);
        text-shadow: 2px 2px 0 var(--ink);
        text-transform: uppercase;
        margin-bottom: 0.5rem;
        transition: text-shadow var(--duration-base);
      }
      .porto-panel:hover .porto-title {
        text-shadow: 3px 3px 0 var(--pink);
      }
      .porto-desc {
        font-size: var(--text-sm);
        color: var(--color-text-muted);
        line-height: 1.6;
      }
      .porto-panel-footer {
        padding: 0.75rem 1.25rem;
        border-top: var(--border-thin);
      }

      /* PAKET */
      .paket-section {
        background: var(--paper);
      }
      .paket-header {
        text-align: center;
        margin-bottom: 3rem;
      }
      .paket-h2 {
        font-size: clamp(2rem, 5vw, 3.5rem);
        margin-bottom: 0.75rem;
      }
      .paket-sub {
        color: var(--color-text-muted);
        max-width: 500px;
        margin: 0 auto 1.5rem;
      }
      .paket-promo-tag {
        margin-top: 1rem;
      }
      .paket-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 0;
        border: var(--border-thick);
        box-shadow: var(--shadow-xl);
        align-items: stretch;
      }
      @media (max-width: 1100px) {
        .paket-grid {
          grid-template-columns: repeat(2, 1fr);
        }
      }
      @media (max-width: 640px) {
        .paket-grid {
          grid-template-columns: 1fr;
        }
      }
      .paket-card {
        padding: 2rem 1.5rem;
        border-right: var(--border-base);
        position: relative;
        transition:
          transform var(--duration-slow) var(--ease-bounce),
          box-shadow var(--duration-slow);
        display: flex;
        flex-direction: column;
        gap: 0;
      }
      .paket-card:last-child {
        border-right: none;
      }
      .paket-card:hover {
        transform: translateY(-6px);
        z-index: 2;
      }
      .paket-card.card {
        border-radius: 0;
        margin: 0;
      }
      .paket-badge-row {
        margin-bottom: 1rem;
      }
      .paket-icon-area {
        margin-bottom: 1rem;
        height: 100px;
        display: flex;
        align-items: center;
      }
      .paket-3d-canvas {
        display: block;
        transition: transform var(--duration-base) var(--ease-bounce);
      }
      .paket-card:hover .paket-3d-canvas {
        transform: scale(1.1) rotate(-5deg);
      }
      .paket-name {
        font-family: var(--font-comic);
        font-size: 1.5rem;
        -webkit-text-stroke: 1.5px var(--ink);
        text-shadow: 3px 3px 0 var(--ink);
        text-transform: uppercase;
        line-height: 1.1;
        margin-bottom: 0.5rem;
      }
      .paket-desc {
        font-size: var(--text-sm);
        color: var(--color-text-muted);
        margin-bottom: 1.25rem;
        min-height: 2.5rem;
      }
      .paket-price-block {
        margin-bottom: 1.25rem;
      }
      .paket-old-price {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        color: var(--color-text-subtle);
        text-decoration: line-through;
        margin-bottom: 0.2rem;
      }
      .paket-price {
        font-family: var(--font-comic);
        font-size: 2rem;
        -webkit-text-stroke: 1px var(--ink);
        text-shadow: 3px 3px 0 var(--ink);
        text-transform: uppercase;
        line-height: 1;
      }
      .paket-duration {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        color: var(--color-text-subtle);
        margin-top: 0.3rem;
      }
      .paket-features {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 0.7rem;
        margin-bottom: 1.5rem;
        flex: 1;
      }
      .paket-features li {
        display: flex;
        gap: 0.6rem;
        align-items: flex-start;
        font-size: var(--text-sm);
        color: var(--color-text-muted);
        line-height: 1.5;
      }
      .feat-check {
        color: #06d6a0;
        font-weight: 900;
        flex-shrink: 0;
        font-size: 0.9rem;
      }
      .paket-featured {
        background: var(--ink) !important;
        border-right-color: rgba(255, 255, 255, 0.1) !important;
      }
      .paket-featured.card-dark {
        box-shadow: none;
      }
      .paket-featured-sticker {
        position: absolute;
        top: -20px;
        right: 16px;
        z-index: 5;
      }
      .sticker-svg {
        width: 80px;
        height: 80px;
        filter: drop-shadow(2px 2px 0 var(--ink));
      }
      .paket-vip {
        background: var(--paper-white) !important;
      }
      .paket-vip::before {
        content: "";
        position: absolute;
        inset: 0;
        background: var(--speedlines);
        opacity: 0.5;
        pointer-events: none;
      }
      .paket-note {
        text-align: center;
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        color: var(--color-text-subtle);
        margin-top: 1.5rem;
      }

      /* PROSES */
      .proses-section {
        position: relative;
      }
      .proses-bg-yellow {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 6px;
        background: var(--yellow);
        border-bottom: var(--border-thin);
      }
      .proses-h2 {
        font-size: clamp(2rem, 5vw, 3.5rem);
        margin: 1rem 0 3rem;
      }
      .proses-storyboard {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 0;
        border: var(--border-thick);
        box-shadow: var(--shadow-xl);
      }
      @media (max-width: 900px) {
        .proses-storyboard {
          grid-template-columns: repeat(2, 1fr);
        }
      }
      @media (max-width: 540px) {
        .proses-storyboard {
          grid-template-columns: 1fr;
        }
      }
      .proses-stb-item {
        position: relative;
        border-right: var(--border-base);
        display: flex;
        flex-direction: column;
      }
      .proses-stb-item:last-child {
        border-right: none;
      }
      .proses-stb-panel {
        background: var(--paper-white);
        border-bottom: var(--border-base);
        padding: 2rem 1.5rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        position: relative;
        min-height: 160px;
        overflow: hidden;
      }
      .proses-stb-pink {
        background: var(--pink-pale);
      }
      .proses-stb-cyan {
        background: var(--cyan-pale);
      }
      .proses-stb-num {
        position: absolute;
        top: 0.75rem;
        left: 1rem;
        font-family: var(--font-comic);
        font-size: 2.5rem;
        color: var(--ink);
        opacity: 0.08;
        -webkit-text-stroke: 1px var(--ink);
        line-height: 1;
      }
      .proses-stb-img {
        position: relative;
        z-index: 2;
        display: flex;
        align-items: center;
        justify-content: center;
        height: 80px;
      }
      .step-3d-canvas {
        display: block;
      }
      .proses-stb-speedlines {
        position: absolute;
        inset: 0;
        background: var(--speedlines);
        opacity: 0;
        transition: opacity var(--duration-base);
        pointer-events: none;
      }
      .proses-stb-item:hover .proses-stb-speedlines {
        opacity: 0.7;
      }
      .proses-stb-content {
        padding: 1.5rem;
        background: var(--paper-white);
        flex: 1;
      }
      .proses-stb-title {
        font-family: var(--font-display);
        font-size: 1rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: var(--ink);
        margin-bottom: 0.5rem;
      }
      .proses-stb-desc {
        font-size: var(--text-sm);
        color: var(--color-text-muted);
        line-height: var(--leading-relaxed);
      }
      .proses-stb-arrow {
        position: absolute;
        top: 50%;
        right: -16px;
        transform: translateY(-50%);
        z-index: 5;
        width: 32px;
        height: 32px;
        background: var(--yellow);
        border: var(--border-base);
        box-shadow: var(--shadow-xs);
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: var(--font-display);
        font-weight: 700;
        font-size: 1rem;
        color: var(--ink);
      }
      @media (max-width: 900px) {
        .proses-stb-arrow {
          display: none;
        }
      }

      /* FAQ */
      .faq-section {
        background: var(--paper-cream);
      }
      .faq-h2 {
        font-size: clamp(2rem, 5vw, 3rem);
        margin: 1rem 0 2.5rem;
      }
      .faq-comic-list {
        border: var(--border-thick);
        box-shadow: var(--shadow-xl);
        overflow: hidden;
      }
      .faq-comic-item {
        border-bottom: var(--border-base);
      }
      .faq-comic-item:last-child {
        border-bottom: none;
      }
      .faq-comic-q {
        list-style: none;
        cursor: pointer;
        padding: 1.25rem 1.5rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        background: var(--paper-white);
        font-family: var(--font-display);
        font-weight: 700;
        font-size: var(--text-base);
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: var(--ink);
        transition:
          background var(--duration-base),
          color var(--duration-base);
        user-select: none;
      }
      .faq-comic-q::-webkit-details-marker {
        display: none;
      }
      .faq-q-num {
        font-family: var(--font-comic);
        font-size: 1.5rem;
        color: var(--cyan);
        -webkit-text-stroke: 1px var(--ink);
        flex-shrink: 0;
        width: 24px;
        text-align: center;
      }
      .faq-q-toggle {
        margin-left: auto;
        font-size: 1.4rem;
        color: var(--pink);
        flex-shrink: 0;
        transition: transform var(--duration-base) var(--ease-spring);
        font-weight: 400;
      }
      .faq-comic-item[open] .faq-comic-q {
        background: var(--ink);
        color: var(--yellow);
      }
      .faq-comic-item[open] .faq-q-num {
        color: var(--yellow);
      }
      .faq-comic-item[open] .faq-q-toggle {
        transform: rotate(45deg);
        color: var(--yellow);
      }
      .faq-comic-a {
        display: flex;
        gap: 1rem;
        padding: 1.25rem 1.5rem;
        background: var(--paper-cream);
        border-top: var(--border-thin);
        align-items: flex-start;
      }
      .faq-a-num {
        font-family: var(--font-comic);
        font-size: 1.5rem;
        color: var(--pink);
        -webkit-text-stroke: 1px var(--ink);
        flex-shrink: 0;
        width: 24px;
        text-align: center;
        margin-top: 0.1rem;
      }
      .faq-comic-a p {
        font-size: var(--text-base);
        color: var(--color-text-muted);
        line-height: var(--leading-relaxed);
      }
      .faq-comic-a p strong {
        color: var(--ink);
      }

      /* SIAP */
      .siap-section {
        background: var(--paper-cream);
      }
      .siap-panel {
        border: var(--border-heavy);
        box-shadow: var(--shadow-xl);
        background: var(--paper-white);
        padding: 3rem;
        position: relative;
        overflow: visible;
      }
      @media (max-width: 640px) {
        .siap-panel {
          padding: 2rem 1.5rem;
        }
      }
      .siap-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        flex-wrap: wrap;
        gap: 1.5rem;
        margin-bottom: 2.5rem;
      }
      .siap-h2 {
        font-size: clamp(2rem, 5vw, 3rem);
      }
      .siap-list {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 0;
        border: var(--border-base);
        margin-bottom: 2rem;
        overflow: hidden;
      }
      .siap-item {
        display: flex;
        align-items: center;
        gap: 1.25rem;
        padding: 1.1rem 1.5rem;
        border-bottom: var(--border-thin);
        background: var(--paper-white);
        transition: background var(--duration-base);
      }
      .siap-item:last-child {
        border-bottom: none;
      }
      .siap-item:hover {
        background: var(--yellow);
      }
      .siap-num {
        width: 36px;
        height: 36px;
        background: var(--pink);
        color: var(--paper-white);
        border: 2.5px solid var(--ink);
        box-shadow: var(--shadow-xs);
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: var(--font-display);
        font-size: 0.9rem;
        font-weight: 700;
        flex-shrink: 0;
      }
      .siap-item:hover .siap-num {
        background: var(--ink);
      }
      .siap-text {
        font-family: var(--font-display);
        font-weight: 600;
        color: var(--ink);
        font-size: var(--text-base);
        text-transform: uppercase;
        letter-spacing: 0.03em;
      }
      .siap-hint {
        font-family: var(--font-hand);
        font-size: 0.85em;
        font-weight: 400;
        color: var(--color-text-muted);
        text-transform: none;
        letter-spacing: 0;
      }
      .siap-cta {
        text-align: center;
      }

      /* KONTAK */
      .kontak-section {
        background: var(--ink);
        position: relative;
        overflow: hidden;
        padding: 6rem 0;
        border-top: var(--border-heavy);
      }
      .kontak-speedlines {
        position: absolute;
        inset: 0;
        background: var(--speedlines);
        opacity: 0.4;
        pointer-events: none;
      }
      .kontak-halftone {
        position: absolute;
        inset: 0;
        background-image: var(--halftone-ink);
        background-size: var(--halftone-size-lg);
        opacity: 0.2;
        pointer-events: none;
      }
      .kontak-inner {
        position: relative;
        z-index: 2;
        text-align: center;
        max-width: 800px;
        margin-inline: auto;
      }
      .kontak-header-bar {
        display: inline-block;
        background: var(--pink);
        border: var(--border-base);
        border-color: var(--pink);
        padding: 0.4rem 1.5rem;
        margin-bottom: 2rem;
        box-shadow: var(--shadow-sm);
      }
      .kontak-h2 {
        font-family: var(--font-comic);
        font-size: clamp(3rem, 10vw, 8rem);
        line-height: 0.9;
        text-transform: uppercase;
        letter-spacing: 0.03em;
        margin-bottom: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.05em;
        align-items: center;
      }
      .h2-outlined {
        color: transparent;
        -webkit-text-stroke: 4px var(--paper-white);
        text-shadow: none;
      }
      .h2-filled {
        color: var(--paper-white);
        -webkit-text-stroke: 2px var(--paper-white);
        text-shadow: 6px 6px 0 var(--pink);
      }
      .h2-splash {
        color: transparent;
        background: linear-gradient(135deg, var(--pink) 0%, var(--cyan) 100%);
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-stroke: 0px;
        text-shadow: none;
        filter: drop-shadow(4px 4px 0 var(--paper-white));
      }
      .kontak-sub {
        color: rgba(253, 252, 248, 0.65);
        font-size: var(--text-lg);
        max-width: 520px;
        margin: 0 auto 2.5rem;
        line-height: var(--leading-relaxed);
      }
      .kontak-btn {
        background: var(--paper-white) !important;
        color: var(--ink) !important;
        border-color: var(--paper-white) !important;
        box-shadow: 5px 5px 0 var(--pink) !important;
        margin-bottom: 2.5rem;
        display: inline-flex;
      }
      .kontak-btn:hover {
        box-shadow: 7px 7px 0 var(--cyan) !important;
        color: var(--ink) !important;
      }
      .kontak-divider {
        display: flex;
        align-items: center;
        gap: 1.25rem;
        max-width: 400px;
        margin: 0 auto 2rem;
      }
      .kdiv-line {
        flex: 1;
        height: 2px;
        background: rgba(255, 255, 255, 0.15);
      }
      .kdiv-text {
        color: rgba(255, 255, 255, 0.4);
        font-size: var(--text-sm);
        white-space: nowrap;
      }
      .kontak-socials {
        display: flex;
        justify-content: center;
        gap: 0.75rem;
        flex-wrap: wrap;
        margin-bottom: 2.5rem;
      }
      .ksocial-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.65rem 1.25rem;
        background: rgba(255, 255, 255, 0.08);
        border: 2px solid rgba(255, 255, 255, 0.2);
        color: var(--paper-white);
        font-family: var(--font-display);
        font-size: var(--text-sm);
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        text-decoration: none;
        transition:
          background var(--duration-base),
          border-color var(--duration-base),
          transform var(--duration-base) var(--ease-spring),
          box-shadow var(--duration-base);
      }
      .ksocial-btn:hover {
        background: var(--pink);
        border-color: var(--pink);
        transform: translate(-2px, -2px);
        box-shadow: var(--shadow-pink);
        color: var(--paper-white);
        text-decoration: none;
      }
      .kontak-tagline {
        color: rgba(255, 255, 255, 0.35);
        font-size: var(--text-sm);
      }

      /* MODAL */
      .modal-bd {
        position: fixed;
        inset: 0;
        z-index: var(--z-modal);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem;
        opacity: 0;
        transition: opacity var(--duration-base);
      }
      .modal-bd:not([hidden]) {
        display: flex;
      }
      .modal-bd.modal-open {
        opacity: 1;
      }
      .modal-overlay {
        position: absolute;
        inset: 0;
        background: rgba(10, 10, 10, 0.75);
        backdrop-filter: blur(4px);
      }
      .modal-box {
        position: relative;
        z-index: 1;
        background: var(--paper-white);
        border: var(--border-heavy);
        box-shadow: var(--shadow-xl);
        width: 100%;
        max-width: 860px;
        max-height: 90vh;
        overflow-y: auto;
        transform: scale(0.92) translateY(20px);
        transition: transform var(--duration-slow) var(--ease-spring);
      }
      .modal-bd.modal-open .modal-box {
        transform: scale(1) translateY(0);
      }
      .modal-close {
        position: absolute;
        top: 1rem;
        right: 1rem;
        z-index: 10;
      }
      .modal-img-wrap {
        position: relative;
        aspect-ratio: 16/9;
        background: var(--paper-cream);
        overflow: hidden;
        border-bottom: var(--border-thick);
      }
      .modal-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }
      .modal-img-ph {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        font-family: var(--font-mono);
        font-size: 0.8rem;
        color: var(--color-text-subtle);
      }
      .modal-img-ph span {
        font-size: 2.5rem;
      }
      .modal-img-speedlines {
        position: absolute;
        inset: 0;
        background: var(--speedlines);
        opacity: 0;
        transition: opacity var(--duration-base);
        pointer-events: none;
      }
      .modal-img-wrap:hover .modal-img-speedlines {
        opacity: 0.3;
      }
      .modal-content {
        padding: 2rem;
