            <div class="client-logo">Toko C</div>
            <div class="client-logo">Corporate D</div>
            <div class="client-logo">Startup E</div>
            <div class="client-logo">Brand F</div>
            <div class="client-logo">Klien A</div>
            <div class="client-logo">UMKM B</div>
