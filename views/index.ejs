                    ><span></span><span></span>
                  </div>
                  <div class="key-row">
                    <span></span><span></span><span></span><span></span
                    ><span></span> <span></span><span></span><span></span
                    ><span></span><span></span>
                  </div>
                  <div class="key-row">
                    <span></span><span></span><span></span><span></span
                    ><span></span> <span></span><span></span><span></span>
                  </div>
                  <div class="key-row key-row-space">
                    <span class="spacebar"></span>
                  </div>
                </div>
              </div>
            </div>

            <!-- Floating UI chips — posisi absolute terhadap .hero-visual-stage -->
            <div class="vis-chip vis-chip-1 animate-pop delay-3">
              <span class="chip-dot" style="background: var(--cyan)"></span>
              <span>Mobile Ready</span>
            </div>
            <div class="vis-chip vis-chip-2 animate-pop delay-4">
              <span class="chip-dot" style="background: var(--pink)"></span>
              <span>SEO Optimized</span>
            </div>
            <div class="vis-chip vis-chip-3 animate-pop delay-5">
              <span
