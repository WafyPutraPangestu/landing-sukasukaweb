            >
            <div class="scroll-arrow-anim">
              <div class="sarrow sarrow-1"></div>
              <div class="sarrow sarrow-2"></div>
            </div>
          </div>
        </div>
      </section>

      <!-- ══ MARQUEE ══ -->
      <div
        class="marquee-section"
        aria-label="Klien yang mempercayai SukaSuka.web"
      >
        <div class="rip-top" aria-hidden="true"></div>
        <div class="marquee-inner-wrap">
          <div class="marquee-track" aria-hidden="true">
            <div class="marquee-slide">
