        text-transform: uppercase;
      }
      .scroll-line {
        width: 1px;
        height: 48px;
        background: linear-gradient(
          to bottom,
          var(--color-brand-400),
          transparent
        );
        animation: scrollLine 2s ease-in-out infinite;
      }
      @keyframes scrollLine {
        0% {
          transform: scaleY(0);
          transform-origin: top;
        }
        49% {
          transform: scaleY(1);
          transform-origin: top;
        }
        50% {
          transform: scaleY(1);
          transform-origin: bottom;
        }
        100% {
          transform: scaleY(0);
          transform-origin: bottom;
        }
      }
      .logo-img-wrap {
        display: inline-block;
      }

      /* MARQUEE */
      .marquee-outer {
        overflow: hidden;
      }
      .marquee-inner {
        display: flex;
        align-items: center;
        gap: 0;
        width: max-content;
        animation: marquee 20s linear infinite;
      }
      .marquee-outer:hover .marquee-inner {
        animation-play-state: paused;
      }
      .client-logo {
        padding: 0 3rem;
        font-family: var(--font-serif);
        font-size: 1.3rem;
        font-weight: 700;
        color: var(--color-text-subtle);
        white-space: nowrap;
        transition: color var(--duration-base);
      }
      .client-logo:hover {
        color: var(--color-text-brand);
      }
      @keyframes marquee {
        from {
          transform: translateX(0);
        }
        to {
          transform: translateX(-50%);
        }
      }

      /* ABOUT */
      .about-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 5rem;
        align-items: center;
      }
      @media (max-width: 768px) {
        .about-grid {
          grid-template-columns: 1fr;
          gap: 3rem;
        }
      }
      .about-frame {
        position: relative;
        border-radius: var(--radius-xl);
        overflow: hidden;
        background: var(--color-bg-tertiary);
        border: 1px solid var(--color-border);
        aspect-ratio: 4/5;
      }
      .about-frame img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }
      .about-frame-deco {
        position: absolute;
        top: -0.75rem;
        left: -0.75rem;
        z-index: 10;
        width: 64px;
        height: 64px;
        border-top: 2px solid var(--color-brand-400);
        border-left: 2px solid var(--color-brand-400);
        border-radius: 4px 0 0 0;
        pointer-events: none;
      }
      .about-badge {
        position: absolute;
        bottom: 1.25rem;
        right: -1rem;
        background: var(--color-bg-card);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-full);
        padding: 0.6rem 1.1rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.78rem;
        font-weight: 600;
        box-shadow: var(--shadow-md);
      }
      .about-stats {
        display: flex;
        align-items: center;
        gap: 2rem;
        padding: 1.5rem;
        background: var(--color-bg-secondary);
        border-radius: var(--radius-lg);
        border: 1px solid var(--color-border);
      }
      .about-stat {
        text-align: center;
        flex: 1;
      }
      .about-stat-num {
        display: inline-block; /* Diubah dari block agar min-width bekerja akurat di tengah */
        min-width: 80px; /* Mengunci lebar kotak agar tidak melebar saat digit bertambah */
        font-variant-numeric: tabular-nums; /* Membuat semua angka punya lebar yang sama (monospace) */

        font-size: 2.25rem;
        font-weight: 800;
        letter-spacing: -0.03em;
        background: var(--gradient-brand);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
      }
      .about-stat-label {
        font-size: 0.72rem;
        color: var(--color-text-subtle);
        font-family: var(--font-mono);
        text-transform: uppercase;
        letter-spacing: 0.08em;
      }
      .about-stat-divider {
        width: 1px;
        height: 40px;
        background: var(--color-border);
        flex-shrink: 0;
      }

      /* PORTO */
      .porto-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.5rem;
      }
      @media (max-width: 640px) {
        .porto-grid {
          grid-template-columns: 1fr;
        }
      }
      .porto-card {
        background: var(--color-bg-card);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-lg);
        overflow: hidden;
        cursor: pointer;
        transition:
          transform var(--duration-slow) var(--ease-spring),
          box-shadow var(--duration-slow) var(--ease-default),
          border-color var(--duration-base);
      }
      .porto-card:hover {
        transform: translateY(-5px);
        box-shadow: var(--shadow-xl);
        border-color: var(--color-border-brand);
      }
      .porto-card:focus-visible {
        outline: 2px solid var(--color-brand-500);
        outline-offset: 3px;
      }
      .porto-img-wrap {
        position: relative;
        aspect-ratio: 16/9;
        overflow: hidden;
        background: var(--color-bg-tertiary);
      }
      .porto-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform var(--duration-slower) var(--ease-default);
      }
      .porto-card:hover .porto-img {
        transform: scale(1.04);
      }
      .porto-img-placeholder {
        position: absolute;
        inset: 0;
        display: none;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 0.4rem;
        color: var(--color-text-subtle);
        font-family: var(--font-mono);
        font-size: 0.72rem;
      }
      .porto-img-placeholder span {
        font-size: 2rem;
      }
      .porto-overlay {
        position: absolute;
        inset: 0;
        background: rgba(0, 0, 0, 0.45);
        backdrop-filter: blur(4px);
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: opacity var(--duration-base);
      }
      .porto-card:hover .porto-overlay {
        opacity: 1;
      }
      .porto-info {
        padding: 1.5rem;
      }
      .porto-title {
        transition: color var(--duration-base);
      }
      .porto-card:hover .porto-title {
        color: var(--color-text-brand);
      }

      /* PROSES */
      .proses-grid {
        display: grid;
        grid-template-columns: 1fr auto 1fr auto 1fr auto 1fr;
        gap: 0;
        align-items: start;
        list-style: none;
        padding: 0;
        margin: 0;
      }
      @media (max-width: 768px) {
        .proses-grid {
          grid-template-columns: 1fr;
        }
        .proses-connector {
          width: 2px;
          height: 40px;
          background: var(--gradient-brand);
          margin: 0 0 0 1.5rem;
        }
      }
      .proses-item {
        padding: 0 1rem;
      }
      .proses-connector {
        width: 60px;
        height: 2px;
        background: var(--gradient-brand);
        margin-top: 1.5rem;
        flex-shrink: 0;
        border-radius: var(--radius-full);
      }
      .proses-num {
        font-family: var(--font-mono);
        font-size: 2rem;
        font-weight: 800;
        background: var(--gradient-brand);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        line-height: 1;
        margin-bottom: 0.75rem;
      }

      /* FAQ */
      .faq-list {
        display: flex;
        flex-direction: column;
        gap: 0;
        border: 1px solid var(--color-border);
        border-radius: var(--radius-lg);
        overflow: hidden;
      }
      .faq-item {
        border-bottom: 1px solid var(--color-border);
      }
      .faq-item:last-child {
        border-bottom: none;
      }
      .faq-question {
        list-style: none;
        cursor: pointer;
        padding: 1.25rem 1.5rem;
        font-weight: 700;
        font-size: 0.95rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        background: var(--color-bg-card);
        transition:
          background var(--duration-base),
          color var(--duration-base);
        user-select: none;
      }
      .faq-question::-webkit-details-marker {
        display: none;
      }
      .faq-question::after {
        content: "+";
        font-size: 1.25rem;
        color: var(--color-text-brand);
        flex-shrink: 0;
        transition: transform var(--duration-base) var(--ease-spring);
      }
      .faq-item[open] .faq-question {
        color: var(--color-text-brand);
        background: var(--color-brand-50);
      }
      .faq-item[open] .faq-question::after {
        transform: rotate(45deg);
      }
      .faq-answer {
        padding: 0 1.5rem 1.25rem;
        background: var(--color-brand-50);
      }
      .faq-answer p {
        font-size: 0.9rem;
        color: var(--color-text-muted);
        line-height: 1.8;
      }

      /* CTA BOX */
      .cta-box {
        background: var(--color-brand-900);
        border-radius: var(--radius-2xl);
        padding: 5rem 2rem;
        text-align: center;
        position: relative;
        overflow: hidden;
        box-shadow: var(--shadow-xl);
      }
      .cta-blob {
        position: absolute;
        border-radius: 50%;
        filter: blur(80px);
        pointer-events: none;
      }
      .cta-blob-1 {
        width: 350px;
        height: 350px;
        top: -100px;
        right: -50px;
        background: var(--color-brand-500);
        opacity: 0.4;
      }
      .cta-blob-2 {
        width: 250px;
        height: 250px;
        bottom: -80px;
        left: -30px;
        background: var(--color-accent-500);
        opacity: 0.25;
      }

      /* MODAL */
      .modal-backdrop {
        position: fixed;
        inset: 0;
        z-index: var(--z-modal);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem;
        opacity: 0;
        transition: opacity var(--duration-base);
      }
      .modal-backdrop:not([hidden]) {
        display: flex;
      }
      .modal-backdrop.modal-open {
        opacity: 1;
      }
      .modal-overlay {
        position: absolute;
        inset: 0;
        background: rgba(0, 0, 0, 0.6);
        backdrop-filter: blur(6px);
      }
      .modal-box {
        position: relative;
        z-index: 1;
        background: var(--color-bg-card);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-xl);
        width: 100%;
        max-width: 860px;
        max-height: 90vh;
        overflow-y: auto;
        transform: scale(0.94) translateY(16px);
        transition: transform var(--duration-slow) var(--ease-spring);
        box-shadow: var(--shadow-xl);
      }
      .modal-backdrop.modal-open .modal-box {
        transform: scale(1) translateY(0);
      }
      .modal-close {
        position: absolute;
        top: 1rem;
        right: 1rem;
        z-index: 10;
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: var(--color-bg-secondary);
        border: 1px solid var(--color-border);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.9rem;
        cursor: pointer;
        color: var(--color-text-muted);
        transition:
          background var(--duration-base),
          color var(--duration-base);
      }
      .modal-close:hover {
        background: var(--color-danger-soft);
        color: var(--color-danger);
      }
      .modal-img-wrap {
        position: relative;
        aspect-ratio: 16/9;
        background: var(--color-bg-tertiary);
        border-radius: var(--radius-xl) var(--radius-xl) 0 0;
        overflow: hidden;
      }
      .modal-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }
      .modal-img-placeholder {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        color: var(--color-text-subtle);
        font-family: var(--font-mono);
        font-size: 0.8rem;
      }
      .modal-img-placeholder span {
        font-size: 2.5rem;
      }
      .modal-content {
        padding: 2rem;
      }
    </style>

    <script>
      // ── MODAL
      const modalEl = document.getElementById("projectModal");
      const modalImg = document.getElementById("modalImage");
      const modalImgPh = document.getElementById("modalImgPlaceholder");
      const modalTitle = document.getElementById("modalTitle");
      const modalDesc = document.getElementById("modalDesc");
      const modalTags = document.getElementById("modalTags");
      const modalLink = document.getElementById("modalLink");

      function openModal({ img, title, desc, tags = [], link = "#" }) {
        modalImg.src = img;
        modalImg.alt = title + " — proyek WebSukaSuka";
        modalImg.style.display = "block";
        modalImgPh.style.display = "none";
        modalImg.onerror = () => {
          modalImg.style.display = "none";
          modalImgPh.style.display = "flex";
        };
        modalTitle.textContent = title;
        modalDesc.textContent = desc;
        modalLink.href = link;
        modalTags.innerHTML = tags
          .map((t) => `<span class="badge badge-neutral">${t}</span>`)
          .join("");
        modalEl.removeAttribute("hidden");
        document.body.style.overflow = "hidden";
        requestAnimationFrame(() => modalEl.classList.add("modal-open"));
      }

      function closeModal() {
        modalEl.classList.remove("modal-open");
        document.body.style.overflow = "";
        setTimeout(() => modalEl.setAttribute("hidden", ""), 300);
      }

      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && !modalEl.hasAttribute("hidden")) closeModal();
      });
      document.querySelectorAll(".porto-card").forEach((card) => {
        card.addEventListener("keydown", (e) => {
          if (e.key === "Enter" || e.key === " ") {
            e.preventDefault();
            card.click();
          }
        });
      });

      // ── SCROLL REVEAL
      document.addEventListener("DOMContentLoaded", () => {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              entry.target.classList.add("visible");
              io.unobserve(entry.target);
            });
          },
          { threshold: 0.12, rootMargin: "0px 0px -40px 0px" },
        );
        document.querySelectorAll(".reveal").forEach((el) => io.observe(el));
      });

      // ── COUNT UP
      function countUp(el, target) {
        let start,
          dur = 1800;
        const step = (ts) => {
          if (!start) start = ts;
          const p = Math.min((ts - start) / dur, 1);
          const e = 1 - Math.pow(1 - p, 3);
          el.textContent = Math.floor(e * target) + "+";
          if (p < 1) requestAnimationFrame(step);
        };
        requestAnimationFrame(step);
      }
      const countIO = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              countUp(e.target, parseInt(e.target.dataset.count));
              countIO.unobserve(e.target);
            }
          });
        },
        { threshold: 0.6 },
      );
      document
        .querySelectorAll("[data-count]")
        .forEach((el) => countIO.observe(el));
    </script>
  </body>
</html>
