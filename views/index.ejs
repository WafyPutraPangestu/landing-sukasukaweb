                style="background: var(--yellow-warm)"
              ></span>
              <span>Fast Loading</span>
            </div>

            <!-- Halftone dot decoration -->
            <div class="vis-dots" aria-hidden="true"></div>
          </div>
        </div>

        <!-- ══ HERO CONTENT ══ -->
        <div class="container hero-content-wrap">
          <div class="hero-content">
            <div class="hero-badge-row" data-anim="fade-up" data-delay="0">
              <div class="inline-flex items-center gap-2 badge badge-dark">
                <span class="status-dot"></span>
                OPEN FOR PROJECT
              </div>
            </div>

            <div class="hero-logo-wrap" data-anim="fade-up" data-delay="80">
              <img
