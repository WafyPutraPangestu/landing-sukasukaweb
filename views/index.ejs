                toonMat(PINK),
              );
              bg.rotation.x = Math.PI / 2;
              group.add(bg);
              addOutline(
                new THREE.CylinderGeometry(0.9, 0.9, 0.3, 20),
                bg,
                1.05,
              );
              // tail
              const tGeo = new THREE.ConeGeometry(0.2, 0.4, 4);
              const tail = new THREE.Mesh(tGeo, toonMat(PINK));
              tail.position.set(-0.4, -0.8, 0);
              tail.rotation.z = 0.5;
              group.add(tail);
              addOutline(tGeo, tail, 1.05);
              // dots inside bubble
              [-0.35, 0, 0.35].forEach((x) => {
                const d = new THREE.Mesh(
                  new THREE.SphereGeometry(0.12, 8, 8),
                  toonMat(WHITE),
                );
                d.position.set(x, 0, 0.18);
                group.add(d);
              });
            } else if (type === "price") {
              // Coin stack
              for (let i = 0; i < 3; i++) {
                const cg = new THREE.CylinderGeometry(0.7, 0.7, 0.22, 20);
                const coin = new THREE.Mesh(cg, toonMat(YELLW));
                coin.position.y = i * 0.28 - 0.3;
                group.add(coin);
                addOutline(cg, coin, 1.04);
                const txt = new THREE.Mesh(
                  new THREE.CylinderGeometry(0.45, 0.45, 0.04, 20),
                  toonMat(INK),
                );
                txt.position.y = coin.position.y + 0.12;
                group.add(txt);
              }
            } else if (type === "shield") {
              // Shield shape from box + cylinder
              const body = new THREE.Mesh(
                new THREE.BoxGeometry(1.2, 1.1, 0.22),
                toonMat(0x06d6a0),
              );
              group.add(body);
              addOutline(new THREE.BoxGeometry(1.2, 1.1, 0.22), body, 1.06);
              const tip = new THREE.Mesh(
                new THREE.ConeGeometry(0.6, 0.6, 4),
                toonMat(0x06d6a0),
              );
              tip.position.y = -0.85;
              tip.rotation.y = Math.PI / 4;
              group.add(tip);
              // Checkmark (two boxes at angle)
              const ck1 = new THREE.Mesh(
                new THREE.BoxGeometry(0.5, 0.1, 0.1),
                toonMat(WHITE),
              );
              ck1.position.set(-0.15, 0, 0.14);
              ck1.rotation.z = Math.PI / 4;
              group.add(ck1);
              const ck2 = new THREE.Mesh(
                new THREE.BoxGeometry(0.3, 0.1, 0.1),
                toonMat(WHITE),
              );
              ck2.position.set(0.2, 0.1, 0.14);
              ck2.rotation.z = -Math.PI / 3;
              group.add(ck2);
            }

            group.rotation.x = 0.2;
            group.rotation.y = -0.3;

            let t = 0;
            function animate() {
              requestAnimationFrame(animate);
              t += 0.015;
              group.rotation.y = -0.3 + Math.sin(t) * 0.2;
              group.position.y = Math.sin(t * 0.9) * 0.06;
              renderer.render(scene, camera);
            }
            animate();

            // Hide fallback emoji
            const emoji = canvas.nextElementSibling;
            if (emoji && emoji.classList.contains("panel-emoji-fallback"))
              emoji.style.display = "none";
          });
        }

        /* ══════════════════════════════════════
