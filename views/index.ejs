        padding: 1.5rem;
      }
      @media (min-width: 640px) {
        .modal-content {
          padding: 2rem;
        }
      }
    </style>

    <script>
      // ── MODAL
      const modalEl = document.getElementById("projectModal");
      const modalImg = document.getElementById("modalImage");
      const modalImgPh = document.getElementById("modalImgPlaceholder");
      const modalTitle = document.getElementById("modalTitle");
      const modalDesc = document.getElementById("modalDesc");
      const modalTags = document.getElementById("modalTags");
      const modalLink = document.getElementById("modalLink");

      function openModal({ img, title, desc, tags = [], link = "#" }) {
        modalImg.src = img;
        modalImg.alt = title + " — proyek SukaSuka.web";
        modalImg.style.display = "block";
        modalImgPh.style.display = "none";
        modalImg.onerror = () => {
          modalImg.style.display = "none";
          modalImgPh.style.display = "flex";
        };
        modalTitle.textContent = title;
        modalDesc.textContent = desc;
        modalLink.href = link;
        modalTags.innerHTML = tags
          .map((t) => `<span class="badge badge-neutral">${t}</span>`)
          .join("");
        modalEl.removeAttribute("hidden");
        document.body.style.overflow = "hidden";
        requestAnimationFrame(() => modalEl.classList.add("modal-open"));
      }

      function closeModal() {
        modalEl.classList.remove("modal-open");
        document.body.style.overflow = "";
        setTimeout(() => modalEl.setAttribute("hidden", ""), 300);
      }

      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && !modalEl.hasAttribute("hidden")) closeModal();
      });
      document.querySelectorAll(".porto-card").forEach((card) => {
        card.addEventListener("keydown", (e) => {
          if (e.key === "Enter" || e.key === " ") {
            e.preventDefault();
            card.click();
          }
        });
      });

      // ── SCROLL REVEAL
      document.addEventListener("DOMContentLoaded", () => {
        const io = new IntersectionObserver(
          (entries) =>
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              entry.target.classList.add("visible");
              io.unobserve(entry.target);
            }),
          { threshold: 0.12, rootMargin: "0px 0px -40px 0px" },
        );
        document.querySelectorAll(".reveal").forEach((el) => io.observe(el));
      });
    </script>
  </body>
</html>
