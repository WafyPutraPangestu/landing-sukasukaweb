      <!-- ══════════════════════════════════════════════════════════
           SECTION 2: TENTANG — Split panel manga layout
           ══════════════════════════════════════════════════════════ -->
      <section
        id="tentang"
        class="section about-section"
        aria-labelledby="about-heading"
      >
        <div class="container">
          <div class="section-chapter-mark reveal">
            <span class="stamp stamp-pink">Chapter 01</span>
          </div>
          <div class="about-panel-grid">
            <div class="about-photo-panel reveal">
              <div class="about-manga-frame">
                <div class="manga-corner-tl" aria-hidden="true"></div>
                <div class="manga-corner-br" aria-hidden="true"></div>
                <div class="about-photo-inner">
                  <img
                    src="/images/tim.jpeg"
                    alt="Tim developer SukaSuka.web"
                    width="480"
                    height="600"
                    loading="lazy"
                    class="about-photo"
                  />
                  <div class="about-photo-halftone" aria-hidden="true"></div>
                </div>
                <div class="about-float-chip chip-tl animate-float delay-1">
                  <span class="status-dot"></span>
                  <span
                    class="font-display text-xs font-bold"
                    style="text-transform: uppercase; letter-spacing: 0.1em"
                    >Tim Aktif</span
                  >
                </div>
                <div class="about-float-bubble animate-float delay-3">
                  <div class="bubble bubble-cyan" style="font-size: 0.8rem">
                    Kami ngerjain langsung!
                  </div>
                </div>
              </div>
              <div class="about-tech-row">
                <span class="stamp stamp-ink tilt-left-sm">Node.js</span>
                <span class="stamp stamp-cyan tilt-right-sm">Next.js</span>
                <span class="stamp stamp-pink tilt-left-sm">Laravel</span>
              </div>
            </div>

            <div class="about-content-panel">
              <span class="section-tag reveal">Tentang Kami</span>
              <h2 id="about-heading" class="reveal delay-1 about-h2">
                <!-- Jadikan putih agar outline hitamnya terlihat -->
                <span class="text-paper">Tim Developer</span><br />

                <!-- Matikan stroke dan ganti shadow dengan drop-shadow agar gradient tidak tertimpa -->
                <span
                  class="text-splash"
                  style="
                    -webkit-text-stroke: 0px;
                    text-shadow: none;
                    filter: drop-shadow(3px 3px 0 var(--ink));
                  "
                >
                  Muda
                </span>
                <span class="text-paper">dengan</span><br />

                <span
                  class="font-hand"
                  style="
                    font-size: 0.7em;
                    -webkit-text-stroke: 0px;
                    text-shadow: none;
                    color: var(--pink);
                  "
                >
                  Semangat Tinggi ✦
                </span>
              </h2>
              <p class="reveal delay-2 about-p">
                <strong>SukaSuka.web</strong> adalah tim developer dan desainer
                muda berbasis di Indonesia. Kami percaya website bagus
                seharusnya bisa diakses semua bisnis — bukan hanya perusahaan
                besar.
              </p>
              <p class="reveal delay-3 about-p">
                Spesialis membangun
                <strong>web app, landing page, company profile</strong>, hingga
                <strong>sistem kasir (POS)</strong> dengan tech stack terkini
                dan harga UMKM-friendly.
              </p>
              <!-- 3D Icon mini scene untuk about stats -->
              <div class="about-stats-grid reveal delay-4">
                <div class="hero-stat-item">
                  <span class="stat-number" style="color: var(--paper-white)"
                    >Laravel</span
                  >
                  <span class="stat-label">Tech Stack Modern</span>
                </div>

                <div class="hero-stat-item">
                  <span class="stat-number" style="color: var(--paper-white)"
                    >&lt;24 Jam</span
                  >
                  <span class="stat-label">Respon WhatsApp</span>
                </div>

                <div class="hero-stat-item">
                  <span class="stat-number" style="color: var(--yellow)"
                    >DP 50%</span
                  >
                  <span class="stat-label">Bayar Setelah Jadi</span>
                </div>
              </div>
              <div class="about-ink-deco reveal delay-5" aria-hidden="true">
                <svg
                  viewBox="0 0 300 20"
                  fill="none"
                  style="width: 100%; max-width: 300px"
                >
                  <path
                    d="M0 10 Q75 2 150 10 Q225 18 300 10"
                    stroke="var(--pink)"
                    stroke-width="3"
                    fill="none"
                    stroke-dasharray="8 4"
                  />
                </svg>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ══════════════════════════════════════════════════════════
           SECTION 3: KENAPA KAMI — 4-panel manga grid dengan mini 3D icons
           ══════════════════════════════════════════════════════════ -->
      <section
        id="kenapa"
        class="section kenapa-section"
        aria-labelledby="kenapa-heading"
      >
        <div class="kenapa-halftone-bg" aria-hidden="true"></div>
        <div class="container" style="position: relative; z-index: 2">
          <div class="section-header-split reveal">
            <div>
              <span class="section-tag">Kenapa Kami?</span>
              <h2 id="kenapa-heading" class="kenapa-h2">
                <span class="text-paper">Bukan Agency Besar</span><br />

                <span
                  class="text-outlined-pink"
                  style="color: var(--paper-white)"
                  >TAPI LEBIH</span
                ><br />

                <span
                  class="text-splash"
                  style="
                    -webkit-text-stroke: 0px;
                    text-shadow: none;
                    filter: drop-shadow(3px 3px 0 var(--ink));
                  "
                  >PERSONAL</span
                >
              </h2>
            </div>
            <div class="kenapa-note reveal delay-2">
              <div
                class="bubble bubble-pink"
                style="max-width: 200px; font-size: 0.85rem"
              >
                Kamu ngobrol langsung<br />sama yang ngerjain! 💬
              </div>
            </div>
          </div>

          <div class="kenapa-manga-grid">
            <article
              class="kenapa-panel tilt-card reveal delay-1"
              aria-labelledby="kp1"
            >
              <div class="panel-num" aria-hidden="true">01</div>
              <div class="panel-burst" aria-hidden="true"></div>
              <div class="panel-icon-wrap">
                <canvas
                  class="panel-3d-canvas"
                  data-icon="tech"
                  width="80"
                  height="80"
                ></canvas>
                <span class="panel-emoji panel-emoji-fallback">⚡</span>
              </div>
              <h3 id="kp1" class="panel-title text-paper">
                Tech Stack<br />Modern
              </h3>
              <p class="panel-desc">
                Node.js, Laravel Livewire, Tailwind — bukan template lama.
                Website kamu cepat, ringan, dan mudah dikembangkan.
              </p>
              <div class="panel-action-line" aria-hidden="true"></div>
            </article>

            <article
              class="kenapa-panel kenapa-panel-pink tilt-card reveal delay-2"
              aria-labelledby="kp2"
            >
              <div class="panel-num" aria-hidden="true">02</div>
              <div class="panel-burst" aria-hidden="true"></div>
              <div class="panel-icon-wrap">
                <canvas
                  class="panel-3d-canvas"
                  data-icon="chat"
                  width="80"
                  height="80"
                ></canvas>
                <span class="panel-emoji panel-emoji-fallback">💬</span>
              </div>
              <h3 id="kp2" class="panel-title text-paper">
                Langsung ke<br />Developer
              </h3>
              <p class="panel-desc">
                Tidak ada perantara. Kamu ngobrol langsung dengan yang ngerjain
                — lebih cepat, akurat, transparan.
              </p>
              <div class="panel-action-line" aria-hidden="true"></div>
            </article>

            <article
              class="kenapa-panel tilt-card reveal delay-3"
              aria-labelledby="kp3"
            >
              <div class="panel-num" aria-hidden="true">03</div>
              <div class="panel-burst" aria-hidden="true"></div>
              <div class="panel-icon-wrap">
                <canvas
                  class="panel-3d-canvas"
                  data-icon="price"
                  width="80"
                  height="80"
                ></canvas>
                <span class="panel-emoji panel-emoji-fallback">💸</span>
              </div>
              <h3 id="kp3" class="panel-title text-yellow">
                Harga<br />UMKM-Friendly
              </h3>
              <p class="panel-desc">
                Tanpa overhead agency besar. Harga kompetitif dengan kualitas
                desain dan kode profesional.
              </p>
              <div class="panel-action-line" aria-hidden="true"></div>
            </article>

            <article
              class="kenapa-panel kenapa-panel-cyan tilt-card reveal delay-4"
              aria-labelledby="kp4"
            >
              <div class="panel-num" aria-hidden="true">04</div>
              <div class="panel-burst" aria-hidden="true"></div>
              <div class="panel-icon-wrap">
                <canvas
                  class="panel-3d-canvas"
                  data-icon="shield"
                  width="80"
                  height="80"
                ></canvas>
