                        width: 85%;
                        background: var(--cyan);
                        margin-bottom: 6px;
                      "
                    ></div>
                    <div
                      class="code-line"
                      style="
                        width: 45%;
                        background: var(--pink);
                        margin-bottom: 6px;
                      "
                    ></div>
                    <div
                      class="code-line"
                      style="
                        width: 70%;
                        background: var(--cyan);
                        margin-bottom: 6px;
                      "
                    ></div>
                    <div
                      class="code-line"
                      style="
                        width: 55%;
                        background: rgba(10, 10, 10, 0.25);
                        margin-bottom: 6px;
                      "
                    ></div>
                    <div
                      class="code-line"
                      style="
                        width: 80%;
                        background: var(--pink);
                        margin-bottom: 6px;
                      "
