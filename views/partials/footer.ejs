<style>
  /* ── Footer Reset ── */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ── Wrapper ── */
  .site-footer {
    background: var(--color-bg-dark);
    color: var(--color-text-inverse);
    position: relative;
    overflow: hidden;
    /* Speed-lines decorative bg */
    background-image: repeating-conic-gradient(
      from 0deg at 50% 110%,
      transparent 0deg,
      transparent 10deg,
      rgba(247, 37, 133, 0.03) 10deg,
      rgba(247, 37, 133, 0.03) 11deg
    );
    background-color: var(--color-bg-dark);
  }

  /* Halftone dots over footer */
  .site-footer::after {
    content: "";
    position: absolute;
    inset: 0;
    background-image: var(--pattern-dots);
    background-size: 22px 22px;
    opacity: 0.35;
    pointer-events: none;
    z-index: 0;
  }

  .site-footer > * {
    position: relative;
    z-index: 1;
  }

  /* ── Accent bar ── */
  .footer-bar {
    height: 4px;
    background: var(--gradient-brand);
    width: 100%;
  }

  /* ── Inner Layout ── */
  .footer-inner {
    display: grid;
    grid-template-columns: 1.8fr 1fr 1fr 1.2fr;
    gap: 3rem;
    padding-top: 4rem;
    padding-bottom: 3rem;
  }

  /* ── Brand ── */
  .footer-logo-img {
    height: 40px;
    width: auto;
    object-fit: contain;
    filter: brightness(0) invert(1);
    opacity: 0.92;
    margin-bottom: 1.25rem;
    display: block;
  }

  .footer-tagline {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: rgba(253, 252, 250, 0.6);
    line-height: var(--leading-relaxed);
    margin-bottom: 1.5rem;
    max-width: 260px;
  }

  .footer-tagline .text-gradient {
    background: var(--gradient-warm);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-weight: var(--font-weight-bold);
  }

  /* ── WhatsApp Button ── */
  .footer-wa-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: var(--font-weight-bold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: white;
    background: linear-gradient(135deg, #25d366 0%, #128c7e 100%);
    border: 2px solid rgba(37, 211, 102, 0.5);
    box-shadow: 3px 3px 0px #075e54;
    padding: 0.6rem 1.25rem;
    border-radius: var(--radius-full);
    text-decoration: none;
    transition:
      box-shadow var(--duration-base) var(--ease-bounce),
      transform var(--duration-base) var(--ease-bounce);
  }
  .footer-wa-btn:hover {
    box-shadow: 5px 5px 0px #075e54;
    transform: translate(-1px, -1px);
  }
  .footer-wa-btn:active {
    box-shadow: 1px 1px 0px #075e54;
    transform: translate(1px, 1px);
  }

  .footer-wa-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    background: rgba(255, 255, 255, 0.18);
    padding: 2px 8px;
    border-radius: var(--radius-full);
    font-size: 0.6rem;
  }

  /* ── Column Titles ── */
  .footer-col-title {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: var(--font-weight-medium);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-sakura-400);
    margin-bottom: 1.1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(247, 37, 133, 0.25);
    /* Override heading defaults for footer */
    line-height: var(--leading-snug);
  }

  /* ── Nav Links ── */
  .footer-nav {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .footer-link {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: rgba(253, 252, 250, 0.55);
    text-decoration: none;
    padding: 0.25rem 0;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    transition: color var(--duration-base) var(--ease-default);
    position: relative;
  }

  .footer-link::before {
    content: "▸";
    font-size: 0.6rem;
    color: var(--color-sakura-400);
    opacity: 0;
    transform: translateX(-4px);
    transition:
      opacity var(--duration-base) var(--ease-default),
      transform var(--duration-base) var(--ease-spring);
  }

  .footer-link:hover {
    color: var(--color-sakura-300);
  }
  .footer-link:hover::before {
    opacity: 1;
    transform: translateX(0);
  }

  /* ── Contact ── */
  .footer-contact {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .footer-contact-item {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: rgba(253, 252, 250, 0.55);
    text-decoration: none;
    transition: color var(--duration-base) var(--ease-default);
  }
  .footer-contact-item:hover {
    color: var(--color-aqua-400);
  }

  .footer-contact-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    background: rgba(247, 37, 133, 0.12);
    border: 1px solid rgba(247, 37, 133, 0.25);
    border-radius: var(--radius-sm);
    color: var(--color-sakura-400);
    flex-shrink: 0;
    transition:
      background var(--duration-base) var(--ease-default),
      color var(--duration-base) var(--ease-default);
  }
  .footer-contact-item:hover .footer-contact-icon {
    background: rgba(76, 201, 240, 0.15);
    color: var(--color-aqua-400);
    border-color: rgba(76, 201, 240, 0.35);
  }

  .footer-price-tag {
    margin-top: 0.5rem;
  }

  /* Stamp dark version */
  .site-footer .stamp-brand {
    color: var(--color-sakura-300);
    border-color: var(--color-sakura-400);
    background: rgba(247, 37, 133, 0.12);
  }

  /* ── Divider ── */
  .footer-divider {
    height: 1.5px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(247, 37, 133, 0.35) 30%,
      rgba(67, 97, 238, 0.35) 70%,
      transparent 100%
    );
    margin-bottom: 0;
  }

  /* ── Bottom Bar ── */
  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 1.25rem;
    padding-bottom: 1.75rem;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .footer-copy {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: rgba(253, 252, 250, 0.35);
    margin: 0;
    line-height: 1;
  }

  .footer-copy-brand {
    color: var(--color-sakura-400);
    font-weight: var(--font-weight-medium);
  }

  .footer-made {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: rgba(253, 252, 250, 0.35);
    margin: 0;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    line-height: 1;
  }

  .footer-heart {
    color: var(--color-sakura-400);
    animation: pulse-dot 2s ease-in-out infinite;
    display: inline-block;
  }

  .footer-flag {
    font-size: 1rem;
    line-height: 1;
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .footer-inner {
      grid-template-columns: 1.5fr 1fr 1fr;
      gap: 2.5rem;
    }
    .footer-brand {
      grid-column: 1 / -1;
      display: grid;
      grid-template-columns: auto 1fr auto;
      align-items: start;
      gap: 0 2rem;
    }
    .footer-logo-img {
      margin-bottom: 0;
    }
    .footer-tagline {
      max-width: none;
      margin-bottom: 0;
    }
  }

  @media (max-width: 768px) {
    .footer-inner {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
      padding-top: 3rem;
    }
    .footer-brand {
      grid-column: 1 / -1;
      display: block;
    }
    .footer-logo-img {
      margin-bottom: 1rem;
    }
    .footer-tagline {
      max-width: 100%;
    }
    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }
  }

  @media (max-width: 480px) {
    .footer-inner {
      grid-template-columns: 1fr;
    }
  }
</style>

