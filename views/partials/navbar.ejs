<!-- ══════════════════════════════════════════
     NAVBAR STYLES — Neo-Comic Ink UI
     ══════════════════════════════════════════ -->
<style>
  /* ── Nav links list ── */
  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.1rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  /* Override global nav-link for desktop panel feel */
  .navbar .nav-link {
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: var(--label-tracking);
    color: var(--ink);
    padding: 0.4rem 0.85rem;
    border: 2px solid transparent;
    border-radius: var(--radius-xs);
    text-decoration: none;
    position: relative;
    transition:
      color var(--duration-fast) var(--ease-snap),
      background var(--duration-fast) var(--ease-snap),
      border-color var(--duration-fast) var(--ease-snap),
      box-shadow var(--duration-fast) var(--ease-snap),
      transform var(--duration-fast) var(--ease-bounce);
  }

  .navbar .nav-link:hover,
  .navbar .nav-link.active {
    color: var(--pink);
    background: var(--pink-pale);
    border-color: var(--ink);
    box-shadow: var(--shadow-xs);
    transform: translate(-1px, -1px);
    text-decoration: none;
  }

  /* ── Status badge ── */
  .nav-status {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    letter-spacing: var(--mono-tracking);
    color: var(--color-text-muted);
    background: var(--paper-cream);
    border: var(--border-thin);
    padding: 0.3rem 0.7rem;
    border-radius: var(--radius-xs);
    box-shadow: var(--shadow-xs);
    white-space: nowrap;
  }

  /* ── Actions wrapper ── */
  .nav-actions {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  /* ── Logo image ── */
  .nav-logo-img {
    display: block;
    height: 34px;
    width: auto;
    object-fit: contain;
  }

  /* ── Hamburger — overrides global .nav-hamburger ── */
  .nav-hamburger {
    display: none;
  }

  /* ════════════════════════════════════════
     MOBILE MENU — full-screen ink panel
     ════════════════════════════════════════ */
  .mobile-menu {
    position: fixed;
    inset: 0;
    z-index: calc(var(--z-sticky) - 1);

    /* Ink panel background with halftone overlay */
    background-color: var(--paper-white);
    background-image: var(--halftone-ink);
    background-size: var(--halftone-size-lg);

    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding: 2rem;

    /* Comic panel border */
    border-top: var(--border-heavy);

    /* Hidden state */
    opacity: 0;
    pointer-events: none;
    transform: translateY(-16px) rotate(-1deg);
    transform-origin: top center;
    transition:
      opacity var(--duration-slow) var(--ease-spring),
      transform var(--duration-slow) var(--ease-spring);
  }

  .mobile-menu.is-open {
    opacity: 1;
    pointer-events: all;
    transform: translateY(0) rotate(0deg);
  }

  /* "MENU" comic panel label */
  .mobile-panel-label {
    font-family: var(--font-comic);
    font-size: var(--text-xs);
    letter-spacing: var(--label-tracking);
    color: var(--color-text-subtle);
    -webkit-text-stroke: 0.5px var(--ink);
    position: absolute;
    top: 1.1rem;
    left: 50%;
    transform: translateX(-50%);
    pointer-events: none;
    user-select: none;
  }

  /* Pink corner decoration */
  .mobile-menu::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 70px;
    height: 70px;
    background: var(--pink);
    clip-path: polygon(0 0, 100% 0, 0 100%);
    pointer-events: none;
  }

  /* Cyan corner decoration (bottom-right) */
  .mobile-menu::after {
    content: "";
    position: absolute;
    bottom: 0;
    right: 0;
    width: 70px;
    height: 70px;
    background: var(--cyan);
    clip-path: polygon(100% 0, 100% 100%, 0 100%);
    pointer-events: none;
  }

  /* Nav link list */
  .mobile-nav-links {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
    width: 100%;
    max-width: 340px;
  }

  /* Individual mobile link — comic stamp style */
  .mobile-nav-link {
    display: block;
    width: 100%;
    text-align: center;
    font-family: var(--font-comic);
    font-size: var(--text-2xl);
    font-weight: 400;
    letter-spacing: var(--comic-tracking);
    text-transform: uppercase;
    color: var(--ink);
    -webkit-text-stroke: 1px var(--ink);
    text-shadow: 2px 2px 0px rgba(10, 10, 10, 0.1);
    padding: 0.65rem 1.5rem;
    border: var(--border-thick);
    background: var(--paper-white);
    box-shadow: var(--shadow-sm);
    text-decoration: none;
    border-radius: var(--radius-xs);
    transition:
      background var(--duration-base) var(--ease-snap),
      color var(--duration-base) var(--ease-snap),
      box-shadow var(--duration-base) var(--ease-snap),
      transform var(--duration-base) var(--ease-bounce);
  }

  .mobile-nav-link:hover {
    background: var(--pink);
    color: var(--paper-white);
    -webkit-text-stroke: 1px var(--paper-white);
    box-shadow: var(--shadow-md);
    transform: translate(-2px, -2px);
    text-decoration: none;
  }

  .mobile-cta {
    margin-top: 0.5rem;
    width: 100%;
    max-width: 340px;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .nav-status-text {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .nav-links,
    .nav-status,
    .nav-cta {
      display: none;
    }

    .nav-hamburger {
      display: flex;
    }
  }
</style>

<!-- ══════════════════════════════════════════
     NAVBAR SCRIPT
     ══════════════════════════════════════════ -->
<script>
  (function () {
    const nav = document.getElementById("mainNav");
    const hamburger = document.getElementById("navHamburger");
    const mobileMenu = document.getElementById("mobileMenu");
    const closeLinks = mobileMenu.querySelectorAll("[data-close]");

    /* ── Scroll: add .scrolled class ── */
    const onScroll = () =>
      nav.classList.toggle("scrolled", window.scrollY > 32);
    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll();

    /* ── Active nav link highlight via IntersectionObserver ── */
    const navLinks = document.querySelectorAll(".navbar .nav-link");
    const sections = ["beranda", "layanan", "portofolio", "kontak"];

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const id = entry.target.id;
            navLinks.forEach((link) => {
              link.classList.toggle(
                "active",
                link.getAttribute("href") === `/#${id}`,
              );
            });
          }
        });
      },
      { rootMargin: "-40% 0px -55% 0px", threshold: 0 },
    );
    sections.forEach((id) => {
      const el = document.getElementById(id);
      if (el) observer.observe(el);
    });

    /* ── Mobile menu toggle ── */
    const openMenu = () => {
      mobileMenu.classList.add("is-open");
      mobileMenu.setAttribute("aria-hidden", "false");
      hamburger.setAttribute("aria-expanded", "true");
      document.body.style.overflow = "hidden";
    };

    const closeMenu = () => {
      mobileMenu.classList.remove("is-open");
      mobileMenu.setAttribute("aria-hidden", "true");
      hamburger.setAttribute("aria-expanded", "false");
      document.body.style.overflow = "";
    };

    hamburger.addEventListener("click", () => {
      hamburger.getAttribute("aria-expanded") === "true"
        ? closeMenu()
        : openMenu();
    });

    closeLinks.forEach((link) => link.addEventListener("click", closeMenu));
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") closeMenu();
    });
  })();
</script>
