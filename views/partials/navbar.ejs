<header class="navbar" id="navbar">
  <!-- Logo -->
  <a href="/" class="nav-logo">
    <img
      src="/images/logo-atas.png"
      alt="Suka-Suka Web"
      class="h-10 w-auto mx-auto"
    />
  </a>

  <!-- Desktop Nav -->
  <nav class="hidden md:flex items-center gap-1">
    <a href="/#beranda" class="nav-link">Beranda</a>
    <a href="/#layanan" class="nav-link">Layanan</a>
    <a href="/#portofolio" class="nav-link">Portofolio</a>
    <a href="/#kontak" class="nav-link">Kontak</a>
  </nav>

  <!-- Right Side -->
  <div class="flex items-center gap-4">
    <div class="hidden lg:flex items-center gap-2">
      <span class="status-dot"></span>
      <span
        class="font-mono text-[var(--text-xs)] text-[var(--color-text-muted)] tracking-widest uppercase"
      >
        Open for Project
      </span>
    </div>
    <a
      href="https://wa.me/6285706193924"
      target="_blank"
      class="btn btn-primary btn-sm"
    >
      Mulai Proyek
    </a>
    <!-- Hamburger (mobile) -->
    <button
      id="menuBtn"
      class="md:hidden flex flex-col gap-1.5 p-1.5 rounded-md hover:bg-[var(--color-bg-tertiary)] transition-colors"
      aria-label="Menu"
    >
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>
